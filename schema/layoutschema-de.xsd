      <xs:element ref="en:b"/>
      <xs:element ref="en:barcode"/>
      <xs:element ref="en:br"/>
      <xs:element ref="en:code"/>
      <xs:element ref="en:div"/>
      <xs:element ref="en:em"/>
      <xs:element ref="en:h1"/>
      <xs:element ref="en:h2"/>
      <xs:element ref="en:h3"/>
      <xs:element ref="en:h4"/>
      <xs:element ref="en:h5"/>
      <xs:element ref="en:h6"/>
      <xs:element ref="en:i"/>
      <xs:element ref="en:img"/>
