  <xs:element name="PlaceObject">
    <xs:annotation>
      <xs:documentation>Gibt ein rechteckiges Objekt (Bild, Tabelle, Box oder TextBlock) aus.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:Box"/>
        <xs:element ref="en:Circle"/>
        <xs:element ref="en:HTML"/>
        <xs:element ref="en:Image"/>
        <xs:element ref="en:Table"/>
        <xs:element ref="en:TextBlock"/>
        <xs:element ref="en:Value"/>
      </xs:choice>
      <xs:attribute name="allocate">
        <xs:annotation>
          <xs:documentation>Bestimmt, ob im Raster der Platz für das Objekt als »belegt« markiert wird. Bei allocate="no" wird auch die aktuelle Zeile im Raster nicht verändert.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes">
              <xs:annotation>
                <xs:documentation>Platz im Raster reservieren (Voreinstellung für Platzierung im Raster).</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="no">
              <xs:annotation>
                <xs:documentation>Bereich nicht als Belegt markieren (Voreinstellung für absolute Positionierung)</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="area">
        <xs:annotation>
          <xs:documentation>Name des Platzierungsbereich, in dem das Objekt ausgegeben werden soll.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="background">
        <xs:annotation>
          <xs:documentation>Erzeugt einen farbigen Hintergrund für das Objekt. Das Attribut »backgroundcolor« gibt die Farbe an.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes"/>
            <xs:enumeration value="no"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="backgroundcolor">
        <xs:annotation>
          <xs:documentation>Hintergrundfarbe wenn das Objekt mit einer Farbe hinterlegt werden soll.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="column">
        <xs:annotation>
          <xs:documentation>Zahl: Die Spalte im Raster, in der das Objekt ausgegeben wird. Wird die Spalte nicht angegeben, so sucht sich das System selbständig eine passende freie Zeile für das Objekt. Maßangabe: die Position von der linken Blattkante.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="frame">
        <xs:annotation>
          <xs:documentation>Es wird ein Rahmen um das Objekt gezeichnet.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes"/>
            <xs:enumeration value="no"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="slate">
        <xs:annotation>
          <xs:documentation>Wenn ein Slate ausgegeben werden soll, muss der Name hier angegeben werden.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="halign">
        <xs:annotation>
          <xs:documentation>Wird ein Objekt ausgegeben, das kein vielfaches der Rasterbreite ist, dann gibt das Attribut die horizontale Ausrichtung an. ›left‹ beispielsweise bedeutet, dass der freie Platz rechts des Objekts bleibt. Voreinstellung ist ›left‹.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:union>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="left">
                  <xs:annotation>
                    <xs:documentation>Das Objekt wird links ausgerichtet.</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="right">
                  <xs:annotation>
                    <xs:documentation>Das Objekt wird rechts ausgerichtet.</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:string">
                <xs:pattern value="\{.+\}"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:union>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="hreference">
        <xs:annotation>
          <xs:documentation>Bestimmt, ob die angegebene Spalte die linke oder die rechte Kante vom Objekt bezeichnet.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:union>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="left">
                  <xs:annotation>
                    <xs:documentation>Das Objekt wird in der angegebenen Spalte platziert.</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="center">
                  <xs:annotation>
                    <xs:documentation>Die angegebene Spalte bestimmt die horizontale Mitte des Objekts.</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="right">
                  <xs:annotation>
                    <xs:documentation>Das Objekt wird mit dem rechten Rand in der gegebenen Spalte am rechten Rand ausgerichtet.</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:string">
                <xs:pattern value="\{.+\}"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:union>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="row">
        <xs:annotation>
          <xs:documentation>Zahl: Die Zeile im Raster, in der das Objekt ausgegeben wird. Wird die Zeile nicht angegeben, so sucht sich das System selbständig eine passende freie Zeile für das Objekt. Maßangabe: die Position von der oberen Blattkante.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="vreference">
        <xs:annotation>
          <xs:documentation>Bestimmt, ob die angegebene Zeile die obere, untere oder mittlere Kante des Objekts bezeichnet.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:union>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="top">
                  <xs:annotation>
                    <xs:documentation>Die angegebene Zeile bestimmt die obere Kante des Objekts (Voreinstellung).</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="middle">
                  <xs:annotation>
                    <xs:documentation>Die angegebene Zeile bestimmt die vertikale Mitte des Objekts.</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="bottom">
                  <xs:annotation>
                    <xs:documentation>Die angegebene Zeile bestimmt die untere Kante des Objekts.</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:string">
                <xs:pattern value="\{.+\}"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:union>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="PositioningArea">
    <xs:annotation>
      <xs:documentation>Beschreibt einen Platzierungsbereich, der mehrere Platzierungsrahmen beinhalten kann. In diesen Rahmen können Elemente platziert werden</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:PositioningFrame"/>
        <xs:element ref="en:Switch"/>
      </xs:choice>
      <xs:attribute name="name" use="required">
        <xs:annotation>
          <xs:documentation>Name des Platzierungsbereichs</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="PositioningFrame">
    <xs:annotation>
      <xs:documentation>Beschreibt einen rechteckigen Bereich, in dem Elemente platziert werden können. Inhalte in diesen Bereichen werden bei Platzmangel automatisch in den nächsten Rahmen desselben Bereichs platziert.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:attribute name="width" use="required">
        <xs:annotation>
          <xs:documentation>Breite des Rahmens in Rasterkästen</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="height" use="required">
        <xs:annotation>
          <xs:documentation>Höhe des Rahmens in Rasterkästen</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="row" use="required">
        <xs:annotation>
          <xs:documentation>Erste Zeile des Rahmens</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="column" use="required">
        <xs:annotation>
          <xs:documentation>Erste Spalte des Rahmens</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="ProcessNode">
    <xs:annotation>
      <xs:documentation>Bearbeitet alle angegebenen Datensätze. Die Elemente, für die die Regeln ausgeführt werden sollen, werden mit dem Attribut select angegeben.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:attribute name="select" use="required">
        <xs:annotation>
          <xs:documentation>Auswahl der Kindelemente, die verarbeitet werden sollen.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="mode">
        <xs:annotation>
          <xs:documentation>Name des Modus. Dieser muss bei Record exakt übereinstimmen. Damit ist es möglich für dasselbe Element unterschiedliche Regeln aufzurufen.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Record">
    <xs:annotation>
      <xs:documentation>Enthält die Anweisungen, die ausgeführt werden, wenn ein Datenelement dem angegebenen Match-Ausdruck entspricht. Der Record, der auf das Wurzelelement passt, wird automatisch aufgerufen; alle weiteren Datensätze müssen über ProcessNode verarbeitet werden. Match-Ausdrücke unterstützen XPath-Prädikate für bedingtes Matching (ähnlich wie XSLT-Template-Matching).</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:sequence maxOccurs="unbounded">
        <xs:element minOccurs="0" ref="en:ClearPage"/>
        <xs:element minOccurs="0" ref="en:ForAll"/>
        <xs:element minOccurs="0" ref="en:Slate"/>
        <xs:element minOccurs="0" ref="en:LoadXML"/>
        <xs:element minOccurs="0" ref="en:Loop"/>
        <xs:element minOccurs="0" ref="en:Message"/>
        <xs:element minOccurs="0" ref="en:NextFrame"/>
        <xs:element minOccurs="0" ref="en:NextRow"/>
        <xs:element minOccurs="0" ref="en:PlaceObject"/>
        <xs:element minOccurs="0" ref="en:ProcessNode"/>
        <xs:element minOccurs="0" ref="en:SaveXML"/>
        <xs:element minOccurs="0" ref="en:SetVariable"/>
        <xs:element minOccurs="0" ref="en:Switch"/>
        <xs:element minOccurs="0" ref="en:Until"/>
        <xs:element minOccurs="0" ref="en:Value"/>
        <xs:element minOccurs="0" ref="en:While"/>
      </xs:sequence>
      <xs:attribute name="match" use="required">
        <xs:annotation>
          <xs:documentation>Ein XPath-Match-Ausdruck. Dies kann ein einfacher Elementname sein (z.B. data) oder ein Elementname gefolgt von einem XPath-Prädikat in eckigen Klammern (z.B. item[@type='invoice'] oder item[not(@hidden='true')]). Wenn mehrere Records auf dasselbe Element passen, haben Records mit Prädikaten Vorrang vor solchen ohne. Bei mehreren passenden Records mit Prädikaten gewinnt der zuletzt definierte.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="mode">
        <xs:annotation>
          <xs:documentation>Name des Modus der mit dem in ProcessNode übereinstimmt.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="SaveXML">
    <xs:annotation>
      <xs:documentation>Speichert eine XML-Datei auf Festplatte. Diese Datei muss als Kindelement hierarchische Struktur, zum Beispiel aus den Befehlen Element und Attribut enthalten, wahlweise zusammengesetzt durch Variablen. Eine ausführlichere Erläuterung findet sich im Abschnitt über automatisch generierte Verzeichnisse.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:sequence maxOccurs="unbounded">
        <xs:element minOccurs="0" ref="en:Element"/>
        <xs:element minOccurs="0" ref="en:ForAll"/>
        <xs:element minOccurs="0" ref="en:Loop"/>
        <xs:element minOccurs="0" ref="en:Value"/>
      </xs:sequence>
      <xs:attribute name="href">
        <xs:annotation>
          <xs:documentation>Name der Dateisatzdatei. Beispiel: toc.xml</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="name">
        <xs:annotation>
          <xs:documentation>Name der Dateisatzdatei. Beispiel: toc</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="elementname" use="required">
        <xs:annotation>
          <xs:documentation>Name des Wurzelelements, das erzeugt wird.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="select">
        <xs:annotation>
          <xs:documentation>Alternativ zur Angabe des Datensatzes im Kindelement.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Section">
    <xs:annotation>
      <xs:documentation>Ein Gliederungselement zur Organisation des Layouts. Hat keinen Einfluss auf die Ausgabe.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:sequence maxOccurs="unbounded">
        <xs:element minOccurs="0" ref="en:DefineColor"/>
        <xs:element minOccurs="0" ref="en:DefineMasterPage"/>
        <xs:element minOccurs="0" ref="en:Function"/>
        <xs:element minOccurs="0" ref="en:Message"/>
        <xs:element minOccurs="0" ref="en:Options"/>
        <xs:element minOccurs="0" ref="en:PDFOptions"/>
        <xs:element minOccurs="0" ref="en:PageFormat"/>
        <xs:element minOccurs="0" ref="en:Record"/>
        <xs:element minOccurs="0" ref="en:Section"/>
        <xs:element minOccurs="0" ref="en:SetGrid"/>
        <xs:element minOccurs="0" ref="en:SetVariable"/>
        <xs:element minOccurs="0" ref="en:StyleSheet"/>
        <xs:element minOccurs="0" ref="en:Trace"/>
      </xs:sequence>
      <xs:attribute name="name" use="required">
        <xs:annotation>
          <xs:documentation>Name dieses Abschnitts (nur zur Dokumentation).</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="SetGrid">
    <xs:annotation>
      <xs:documentation>Setzt die Größe und Höhe eines Rasterkästchens. In dem Seitenraster können Elemente platziert werden.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:attribute name="width">
        <xs:annotation>
          <xs:documentation>Breite einer Rasterzelle. Entweder width oder nx benutzen, nicht beide.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="height">
        <xs:annotation>
          <xs:documentation>Höhe einer Rasterzelle. Entweder höhe oder ny angeben, nicht beide.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="nx">
        <xs:annotation>
          <xs:documentation>Anzahl der Rasterzellen in horizontaler Richtung. Entweder nx oder width angeben.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="ny">
        <xs:annotation>
          <xs:documentation>Gibt die Anzahl der Rasterzellen in vertikaler Richtung an. Entweder ny oder höhe angeben.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="dx">
        <xs:annotation>
          <xs:documentation>Abstand zwischen zwei Rasterzellen (horizontal)</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="dy">
        <xs:annotation>
          <xs:documentation>Abstand zwischen zwei Rasterzellen (horizontal)</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="SetVariable">
    <xs:annotation>
      <xs:documentation>Weist einer Variablen einen Wert zu. Der Wert kann aus mehreren Elementen bestehen (siehe zweites Beispiel).</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:CopyOf"/>
        <xs:element ref="en:Element"/>
        <xs:element ref="en:Paragraph"/>
        <xs:element ref="en:Table"/>
        <xs:element ref="en:TextBlock"/>
        <xs:element ref="en:Until"/>
        <xs:element ref="en:Value"/>
        <xs:element ref="en:While"/>
      </xs:choice>
      <xs:attribute name="select">
        <xs:annotation>
          <xs:documentation>Inhalt, der der Variablen zugewiesen wird.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="trace">
        <xs:annotation>
          <xs:documentation>Zeige Informationen über die Zuweisung in der Logdatei.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes">
              <xs:annotation>
                <xs:documentation>Zeige Informationen.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="no">
              <xs:annotation>
                <xs:documentation>Zeige keine Informationen (Voreinstellung).</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="variable" use="required">
        <xs:annotation>
          <xs:documentation>Name der Variablen, der etwas zugewiesen werden soll.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Span">
    <xs:annotation>
      <xs:documentation>Text mit Style-Optionen umgeben.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:A"/>
        <xs:element ref="en:Action"/>
        <xs:element ref="en:B"/>
        <xs:element ref="en:Br"/>
        <xs:element ref="en:HTML"/>
        <xs:element ref="en:I"/>
        <xs:element ref="en:Ol"/>
        <xs:element ref="en:U"/>
        <xs:element ref="en:Ul"/>
        <xs:element ref="en:Value"/>
        <xs:element ref="en:CopyOf"/>
        <xs:element ref="en:Span"/>
      </xs:choice>
      <xs:attribute name="class">
        <xs:annotation>
          <xs:documentation>CSS Klasse für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="id">
        <xs:annotation>
          <xs:documentation>CSS id für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="style">
        <xs:annotation>
          <xs:documentation>Setze den CSS-Stil.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Switch">
    <xs:annotation>
      <xs:documentation>Erzeugt eine „Wenn-Dann-Abfrage“. Das heißt, für jedes Kindelement Case wird überprüft, ob die Bedingung erfüllt ist. Wenn ja, dann wird der Inhalt des Kindelements Case ausgeführt und die Verarbeitung hinter der Fallunterscheidung fortgesetzt. Wenn keine Bedingung erfüllt wurde und ein Element Otherwise gefunden wurde, wird der         Inhalt des Elements Otherwise ausgeführt. Durch das frühzeitige Abbrechen werden nachfolgende Fälle nicht weiter untersucht (siehe Beispiel).</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="unbounded" ref="en:Case"/>
        <xs:element minOccurs="0" ref="en:Otherwise"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="StyleSheet">
    <xs:annotation>
      <xs:documentation>Lädt eine CSS-Datei oder definiert CSS-Eigenschaften</xs:documentation>
    </xs:annotation>
    <xs:complexType mixed="true">
      <xs:attribute name="href">
        <xs:annotation>
          <xs:documentation>Der Dateiname der CSS Datei (inklusive Dateiendung).</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Table">
    <xs:annotation>
      <xs:documentation>Erzeugt eine Tabelle, die in etwa dem HTML Tabellenmodell entspricht.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:Columns"/>
        <xs:element ref="en:ForAll"/>
        <xs:element ref="en:Loop"/>
        <xs:element ref="en:TableHead"/>
        <xs:element ref="en:TableRule"/>
        <xs:element ref="en:Tr"/>
        <xs:element ref="en:Value"/>
      </xs:choice>
      <xs:attribute name="width">
        <xs:annotation>
          <xs:documentation>Der Bereich, den die Tabelle (maximal) im Raster belegt. Angabe in Rasterzellen oder absoluten Längenangaben. Voreinstellung ist der verfügbare Platz.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="class">
        <xs:annotation>
          <xs:documentation>CSS Klasse für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="id">
        <xs:annotation>
          <xs:documentation>CSS id für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="style">
        <xs:annotation>
          <xs:documentation>CSS Stil für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="stretch">
        <xs:annotation>
          <xs:documentation>Wenn auf "max" gesetzt, wird die Tabelle auf die volle Breite gedehnt (entspricht CSS width: 100%).</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="max">
              <xs:annotation>
                <xs:documentation>Tabelle auf die maximale Breite dehnen.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="TableHead">
    <xs:annotation>
      <xs:documentation>Gibt den Tabellenkopf an.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:ForAll"/>
        <xs:element ref="en:Switch"/>
        <xs:element ref="en:TableRule"/>
        <xs:element ref="en:Tr"/>
      </xs:choice>
    </xs:complexType>
  </xs:element>
  <xs:element name="TableRule">
    <xs:annotation>
      <xs:documentation>Zeichnet eine horizontale Linie über die gesamte Tabellenbreite. Standarddicke ist 0,4 Punkt.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:attribute name="rulewidth">
        <xs:annotation>
          <xs:documentation>Dicke der Linie. Voreinstellung ist 0,4 Punkt.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="color">
        <xs:annotation>
          <xs:documentation>Farbe der Linie. Mit »transparent« wird nur Platz reserviert. Voreinstellung ist schwarz.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="class">
        <xs:annotation>
          <xs:documentation>CSS-Klasse für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="id">
        <xs:annotation>
          <xs:documentation>CSS-ID für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="style">
        <xs:annotation>
          <xs:documentation>CSS-Style für dieses Element. Überschreibt die Attribute rulewidth und color.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Td">
    <xs:annotation>
      <xs:documentation>Erstellt eine Tabellenzelle, wie in HTML</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:Bookmark"/>
        <xs:element ref="en:Box"/>
        <xs:element ref="en:ForAll"/>
        <xs:element ref="en:SlateContents"/>
        <xs:element ref="en:HTML"/>
        <xs:element ref="en:Image"/>
        <xs:element ref="en:Loop"/>
        <xs:element ref="en:Ol"/>
        <xs:element ref="en:Paragraph"/>
        <xs:element ref="en:Switch"/>
        <xs:element ref="en:Table"/>
        <xs:element ref="en:Ul"/>
        <xs:element ref="en:Value"/>
      </xs:choice>
      <xs:attribute name="class">
        <xs:annotation>
          <xs:documentation>Die CSS-Klasse für die Formtierung.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="id">
        <xs:annotation>
          <xs:documentation>CSS id für diese Tabellenzelle.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="style">
        <xs:annotation>
          <xs:documentation>CSS Stil für diese Tabellenzelle.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="colspan">
        <xs:annotation>
          <xs:documentation>Die Anzahl der Spalten, die die Zelle überdecken soll. Voreinstellung ist 1.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="rowspan">
        <xs:annotation>
          <xs:documentation>Die Anzahl der Zeilen, die die Zelle überdecken soll. Voreinstellung ist 1.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="TextBlock">
    <xs:annotation>
      <xs:documentation>Erzeugt einen rechteckigen Bereich mit Text.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice maxOccurs="unbounded">
        <xs:element ref="en:Action"/>
        <xs:element ref="en:ForAll"/>
        <xs:element ref="en:Bookmark"/>
        <xs:element ref="en:HTML"/>
        <xs:element ref="en:Ol"/>
        <xs:element ref="en:Paragraph"/>
        <xs:element ref="en:Ul"/>
        <xs:element ref="en:Value"/>
      </xs:choice>
      <xs:attribute name="parsep">
        <xs:annotation>
          <xs:documentation>Der vertikale Abstand zwischen zwei Absätzen.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="width">
        <xs:annotation>
          <xs:documentation>Anzahl der Spalten, die der Text einnehmen soll. Wenn das Attribut nicht angegeben wird, so bestimmt das umliegende Element die Breite.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Tr">
    <xs:annotation>
      <xs:documentation>Erstellt eine Tabellenzeile</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:sequence maxOccurs="unbounded">
        <xs:element minOccurs="0" ref="en:Message"/>
        <xs:element minOccurs="0" ref="en:Td"/>
        <xs:element minOccurs="0" ref="en:Value"/>
        <xs:element minOccurs="0" ref="en:Switch"/>
        <xs:element minOccurs="0" ref="en:ForAll"/>
        <xs:element minOccurs="0" ref="en:Loop"/>
      </xs:sequence>
      <xs:attribute name="class">
        <xs:annotation>
          <xs:documentation>CSS Klasse für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="id">
        <xs:annotation>
          <xs:documentation>CSS id für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="style">
        <xs:annotation>
          <xs:documentation>CSS Stil für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Trace">
    <xs:annotation>
      <xs:documentation>Setze Debugging-Schalter</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:attribute name="dests">
        <xs:annotation>
          <xs:documentation>Zeige PDF Ziele mit einem schwarzen Kreis.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes">
              <xs:annotation>
                <xs:documentation>Zeige Ziele.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="no">
              <xs:annotation>
                <xs:documentation>Ziele nicht zeigen (Voreinstellung).</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="grid">
        <xs:annotation>
          <xs:documentation>Wenn 'yes', dann zeichnet der Publisher das zugrunde liegende Raster auf die Seiten.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes">
              <xs:annotation>
                <xs:documentation>Zeige das Raster.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="no">
              <xs:annotation>
                <xs:documentation>Das Raster wird nicht angezeigt (Voreinstellung).</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="gridallocation">
        <xs:annotation>
          <xs:documentation>Wenn 'yes', dann markiert der Publisher die belegten Rasterzellen mit einer Hintergrundfarbe.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes">
              <xs:annotation>
                <xs:documentation>Zeige Rasterbelegung.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="no">
              <xs:annotation>
                <xs:documentation>Rasterbelegung nicht zeigen (Voreinstellung).</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="hyperlinks">
        <xs:annotation>
          <xs:documentation>Wenn 'yes', dann zeichnet XTS einen Rahmen um die Hyperlinks.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes">
              <xs:annotation>
                <xs:documentation>Zeige die Hyperlinks.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="no">
              <xs:annotation>
                <xs:documentation>Die Hyperlinks werden nicht angezeigt (Voreinstellung).</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="hyphenation">
        <xs:annotation>
          <xs:documentation>Bei 'yes' markiert der speedata Publisher die möglichen Trennstellen für die Silbentrennung.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes">
              <xs:annotation>
                <xs:documentation>Zeige Silbentrennungsmöglichkeiten.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="no">
              <xs:annotation>
                <xs:documentation>Keine Silbentrennungsmöglichkeiten zeigen (Voreinstellung).</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="objects">
        <xs:annotation>
          <xs:documentation>Zeichnet Kästchen um Objekte.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes">
              <xs:annotation>
                <xs:documentation>Zeige Objekte.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="no">
              <xs:annotation>
                <xs:documentation>Keine Kästchen zeigen.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Ul">
    <xs:annotation>
      <xs:documentation>Erzeugt eine Stichpunktliste mit Aufzählungspunkten</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:Li"/>
        <xs:element ref="en:ForAll"/>
      </xs:choice>
      <xs:attribute name="class">
        <xs:annotation>
          <xs:documentation>CSS Klasse für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="id">
        <xs:annotation>
          <xs:documentation>CSS id für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="style">
        <xs:annotation>
          <xs:documentation>CSS Stil für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="U">
    <xs:annotation>
      <xs:documentation>Unterstreiche Text.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:A"/>
        <xs:element ref="en:Action"/>
        <xs:element ref="en:B"/>
        <xs:element ref="en:Br"/>
        <xs:element ref="en:HTML"/>
        <xs:element ref="en:I"/>
        <xs:element ref="en:Ol"/>
        <xs:element ref="en:U"/>
        <xs:element ref="en:Ul"/>
        <xs:element ref="en:Value"/>
        <xs:element ref="en:CopyOf"/>
        <xs:element ref="en:Span"/>
      </xs:choice>
      <xs:attribute name="class">
        <xs:annotation>
          <xs:documentation>CSS Klasse für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="id">
        <xs:annotation>
          <xs:documentation>CSS id für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="style">
        <xs:annotation>
          <xs:documentation>CSS Stil für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Until">
    <xs:annotation>
      <xs:documentation>Erzeugt eine Schleife. Die Kindelemente werden so oft ausgeführt, bis die Bedingung im Attribut »wahr« ergibt. Der Rückgabewert von Until ist der aneinandergekettete Rückgabewert aller Kindelemente.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:Column"/>
        <xs:element ref="en:ClearPage"/>
        <xs:element ref="en:ForAll"/>
        <xs:element ref="en:HTML"/>
        <xs:element ref="en:LoadXML"/>
        <xs:element ref="en:Loop"/>
        <xs:element ref="en:Li"/>
        <xs:element ref="en:Message"/>
        <xs:element ref="en:NextFrame"/>
        <xs:element ref="en:NextRow"/>
        <xs:element ref="en:Paragraph"/>
        <xs:element ref="en:PlaceObject"/>
        <xs:element ref="en:ProcessNode"/>
        <xs:element ref="en:SaveXML"/>
        <xs:element ref="en:SetVariable"/>
        <xs:element ref="en:Switch"/>
        <xs:element ref="en:Td"/>
        <xs:element ref="en:Tr"/>
        <xs:element ref="en:Until"/>
        <xs:element ref="en:Value"/>
        <xs:element ref="en:While"/>
      </xs:choice>
      <xs:attribute name="test" use="required">
        <xs:annotation>
          <xs:documentation>Nach jedem Schleifendurchlauf wird die Bedingung überprüft. Wenn sie »wahr« ergibt, wird die Schleife verlassen.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="HTML">
    <xs:annotation>
      <xs:documentation>Fügt HTML-Inhalt ein, entweder inline oder per XPath-Ausdruck ermittelt.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:complexContent>
        <xs:extension base="en:html">
          <xs:attribute name="select">
            <xs:annotation>
              <xs:documentation>XPath-Ausdruck, der ein XML/HTML-Fragment liefert.</xs:documentation>
            </xs:annotation>
          </xs:attribute>
          <xs:attribute name="expand-text">
            <xs:annotation>
              <xs:documentation>Bei "yes" werden Ausdrücke in geschweiften Klammern {expr} im HTML-Inhalt als XPath-Ausdrücke ausgewertet (ähnlich wie XSLT 3.0 Text Value Templates). Für literale geschweifte Klammern {{ und }} verwenden. Standard ist "no".</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="yes"/>
                <xs:enumeration value="no"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:attribute>
        </xs:extension>
      </xs:complexContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="Value">
    <xs:annotation>
      <xs:documentation>Beinhaltet einen Textinhalt, der an das umgebende Element übergeben wird (immer als reiner Text).</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:complexContent>
        <xs:extension base="en:anycontent">
          <xs:attribute name="select">
            <xs:annotation>
              <xs:documentation>Wert, der zum umgebenden Element übergeben wird.</xs:documentation>
            </xs:annotation>
          </xs:attribute>
        </xs:extension>
      </xs:complexContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="While">
    <xs:annotation>
      <xs:documentation>Erzeugt eine Schleife, die wiederholt durchlaufen wird. Die Kindelemente werden so oft ausgeführt, solange die Bedingung im Attribut »wahr« ergibt.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:Column"/>
        <xs:element ref="en:ClearPage"/>
        <xs:element ref="en:ForAll"/>
        <xs:element ref="en:HTML"/>
        <xs:element ref="en:LoadXML"/>
        <xs:element ref="en:Loop"/>
        <xs:element ref="en:Li"/>
        <xs:element ref="en:Message"/>
        <xs:element ref="en:NextFrame"/>
        <xs:element ref="en:NextRow"/>
        <xs:element ref="en:Paragraph"/>
        <xs:element ref="en:PlaceObject"/>
        <xs:element ref="en:ProcessNode"/>
        <xs:element ref="en:SaveXML"/>
        <xs:element ref="en:SetVariable"/>
        <xs:element ref="en:Switch"/>
        <xs:element ref="en:Td"/>
        <xs:element ref="en:Tr"/>
        <xs:element ref="en:Until"/>
        <xs:element ref="en:Value"/>
        <xs:element ref="en:While"/>
      </xs:choice>
      <xs:attribute name="test" use="required">
        <xs:annotation>
          <xs:documentation>Für jedes Mal, das die Schleife durchlaufen werden soll, muss die Bedingung im Attribut erfüllt sein. Die Bedingung wird am Anfang der Schleife überprüft. Eine Schleife, bei der die Bedingung am Ende der Schleife geprüft wird, ist Until.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <!-- allow HTML in <Value> ... </Value> -->
  <xs:attributeGroup name="htmlclassidstyle">
    <xs:attribute name="class"/>
    <xs:attribute name="id"/>
    <xs:attribute name="style"/>
  </xs:attributeGroup>
