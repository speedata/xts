              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="duplexfliplongedge">
              <xs:annotation>
                <xs:documentation>Beidseitig und an langer Kante umblättern</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
