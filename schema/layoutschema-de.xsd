  </xs:element>
  <xs:element name="em" type="en:html"/>
  <xs:element name="h1">
    <xs:complexType>
      <xs:complexContent>
        <xs:extension base="en:html">
          <xs:attributeGroup ref="en:htmlclassidstyle"/>
        </xs:extension>
      </xs:complexContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="h2">
    <xs:complexType>
      <xs:complexContent>
        <xs:extension base="en:html">
          <xs:attributeGroup ref="en:htmlclassidstyle"/>
        </xs:extension>
      </xs:complexContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="h3">
    <xs:complexType>
      <xs:complexContent>
        <xs:extension base="en:html">
          <xs:attributeGroup ref="en:htmlclassidstyle"/>
        </xs:extension>
      </xs:complexContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="h4">
    <xs:complexType>
      <xs:complexContent>
        <xs:extension base="en:html">
