      <xs:attribute name="select" use="required">
        <xs:annotation>
          <xs:documentation>Wählt die Kindelemente aus.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Function">
    <xs:annotation>
      <xs:documentation>Definiere eine Funktion</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="en:Param"/>
        <xs:sequence maxOccurs="unbounded">
          <xs:element minOccurs="0" ref="en:ClearPage"/>
          <xs:element minOccurs="0" ref="en:Column"/>
          <xs:element minOccurs="0" ref="en:Columns"/>
          <xs:element minOccurs="0" ref="en:ForAll"/>
          <xs:element minOccurs="0" ref="en:Slate"/>
          <xs:element minOccurs="0" ref="en:LoadXML"/>
          <xs:element minOccurs="0" ref="en:Loop"/>
          <xs:element minOccurs="0" ref="en:Message"/>
          <xs:element minOccurs="0" ref="en:NextFrame"/>
          <xs:element minOccurs="0" ref="en:NextRow"/>
          <xs:element minOccurs="0" ref="en:PlaceObject"/>
          <xs:element minOccurs="0" ref="en:ProcessNode"/>
          <xs:element minOccurs="0" ref="en:SaveXML"/>
          <xs:element minOccurs="0" ref="en:SetVariable"/>
          <xs:element minOccurs="0" ref="en:Switch"/>
          <xs:element minOccurs="0" ref="en:Value"/>
        </xs:sequence>
      </xs:sequence>
      <xs:attribute name="name">
        <xs:annotation>
          <xs:documentation>Der Name der Funktion (mit Namensraum-Präfix)</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Slate">
    <xs:annotation>
      <xs:documentation>Erzeugt einen virtuellen Bereich (Slate), in dem Elemente platziert werden können. Wie bei einer Zaubertafel wird der Inhalt zunächst unsichtbar aufgebaut und dann mit PlaceObject auf der Seite platziert.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:complexContent>
        <xs:extension base="en:e_Contents">
          <xs:attribute name="name" use="required">
            <xs:annotation>
              <xs:documentation>Der Name des anzulegenden Slates.</xs:documentation>
            </xs:annotation>
          </xs:attribute>
        </xs:extension>
      </xs:complexContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="SlateContents">
    <xs:annotation>
      <xs:documentation>Fügt den Inhalt eines zuvor erstellten Slates ein.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:attribute name="name" use="required">
        <xs:annotation>
          <xs:documentation>Name des Slates, dessen Inhalt eingefügt werden soll.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="I">
    <xs:annotation>
      <xs:documentation>Schaltet auf »Kursiv« um.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:A"/>
        <xs:element ref="en:Action"/>
        <xs:element ref="en:B"/>
        <xs:element ref="en:Br"/>
        <xs:element ref="en:HTML"/>
        <xs:element ref="en:I"/>
        <xs:element ref="en:Ol"/>
        <xs:element ref="en:U"/>
        <xs:element ref="en:Ul"/>
        <xs:element ref="en:Value"/>
        <xs:element ref="en:CopyOf"/>
        <xs:element ref="en:Span"/>
      </xs:choice>
    </xs:complexType>
  </xs:element>
  <xs:element name="Image">
    <xs:annotation>
      <xs:documentation>Bindet eine externe Grafik ein. Erlaubte Grafikformate sind PDF (.pdf), PNG (.png) und JPEG (.jpg). Siehe unten für die Einschränkung eingebundener PDF-Dateien.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:attribute name="href">
        <xs:annotation>
          <xs:documentation>Dateiname des Bildes. Kann entweder eine Datei im Suchpfad sein, ein absoluter Dateiname, ein file-URI-Schema (z.B. file:///pfad/zum/bild.pdf) oder eine Quelle im Web (http/https). Mit placeholder://BxH (z.B. placeholder://200x150) wird ein Platzhalterbild mit den angegebenen Maßen in PDF-Punkten erzeugt.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="height">
        <xs:annotation>
          <xs:documentation>Bildhöhe. Angabe in der Form 'auto' (Voreinstellung, natürliche Bildbreite), Längenangabe wie '4cm' oder Zahl (Anzahl von Rasterspalten)</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="page">
        <xs:annotation>
          <xs:documentation>Die Seitenzahl aus dem PDF. Voreinstellung ist 1.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="maxwidth">
        <xs:annotation>
          <xs:documentation>Die maximale Breite des Bilds. Nur, wenn clip="no". Angabe in absoluten Längen, Rasterzellen oder »100%« für volle Breite.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="maxheight">
        <xs:annotation>
          <xs:documentation>Die maximale Breite des Bilds. Nur, wenn clip="no". Angabe in absoluten Längen oder Anzahl Rasterzellen.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="minwidth">
        <xs:annotation>
          <xs:documentation>Die minimale Breite des Bilds. Nur, wenn clip="no". Angabe in absoluten Längen, Rasterzellen oder »100%« für volle Breite.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="minheight">
        <xs:annotation>
          <xs:documentation>Die minimale Breite des Bilds. Nur, wenn clip="no". Angabe in absoluten Längen oder Anzahl Rasterzellen.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="stretch">
        <xs:annotation>
          <xs:documentation>Dehnt das Bild bis eine der Angaben von maxheight und maxwidth erreich ist. Hilfreich um Bilder so groß wie möglich aber innerhalb gewisser Grenzen anzeigen zu lassen.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes"/>
            <xs:enumeration value="no"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="visiblebox">
        <xs:annotation>
          <xs:documentation>Die PDF-Box, die den sichtbaren Bereich angibt des eingebundenen PDFs angibt. Voreinstellung ist »cropbox«.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:union>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="artbox">
                  <xs:annotation>
                    <xs:documentation>Nutze die artbox als sichtbaren Bereich. Diese Box ist normalerweise in PDF-Dateien nicht enthalten.</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="bleedbox">
                  <xs:annotation>
                    <xs:documentation>Nutze die bleedbox des eingebundenen PDFs.</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="cropbox">
                  <xs:annotation>
                    <xs:documentation>Nutze die cropbox der eingebundenen PDF-Datei (Voreinstellung).</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="mediabox">
                  <xs:annotation>
                    <xs:documentation>Nutze die mediabox der eingebundenen PDF-Datei. Das ist die größte Box.</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="trimbox">
                  <xs:annotation>
                    <xs:documentation>Nutze die trimbox der eingebundenen PDF-Datei. Die trimbox ist die Papiergröße. Beispielsweise hat die trimbox eines A4-PDFs die Größe 210mm x 297mm.</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:string">
                <xs:pattern value="\{.+\}"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:union>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="width">
        <xs:annotation>
          <xs:documentation>Bildbreite. Angabe in der Form 'auto' (Voreinstellung, natürliche Bildbreite), '100%' (Breite des aktuellen Platzierungsbereichs), Längenangabe wie '4cm' oder Zahl (Anzahl von Rasterspalten)</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="LoadXML">
    <xs:annotation>
      <xs:documentation>Lädt eine Datensatzdatei, die in einem vorherigen Durchlauf des Publishers erzeugt wurde (Attribut name), oder eine reguläre XML-Datei (Attribut href). Die »normale« Verarbeitung des Layoutregelwerks wird unterbrochen und mit dem Inhalt der Datensatzdatei fortgeführt. Nachdem die Verarbeitung der neu geladenen Datensatzdatei beendet ist, wird die Verarbeitung des Layoutregelwerks mit dem ursprünglichen Datensatz fortgesetzt. Eine ausführlichere Erläuterung findet sich im Abschnitt über automatisch generierte Verzeichnisse.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:attribute name="name">
        <xs:annotation>
          <xs:documentation>Name der Dateisatzdatei. Beispiel: toc</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="href">
        <xs:annotation>
          <xs:documentation>Name der XML-Datei, die geladen werden soll. Beispiel: meinedatei.xml.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Li">
    <xs:annotation>
      <xs:documentation>Listeneintrag in einer Aufzählungsliste (mit Aufzählungspunkten oder nummerierten Punkten).</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:A"/>
        <xs:element ref="en:Action"/>
        <xs:element ref="en:B"/>
        <xs:element ref="en:Br"/>
        <xs:element ref="en:HTML"/>
        <xs:element ref="en:I"/>
        <xs:element ref="en:Ol"/>
        <xs:element ref="en:U"/>
        <xs:element ref="en:Ul"/>
        <xs:element ref="en:Value"/>
        <xs:element ref="en:CopyOf"/>
        <xs:element ref="en:Span"/>
      </xs:choice>
      <xs:attribute name="class">
        <xs:annotation>
          <xs:documentation>CSS Klasse für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="id">
        <xs:annotation>
          <xs:documentation>CSS id für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="style">
        <xs:annotation>
          <xs:documentation>CSS Stil für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Loop">
    <xs:annotation>
      <xs:documentation>Wiederhole den Inhalt dieses Elements mehrfach.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:Column"/>
        <xs:element ref="en:ClearPage"/>
        <xs:element ref="en:ForAll"/>
        <xs:element ref="en:HTML"/>
        <xs:element ref="en:LoadXML"/>
        <xs:element ref="en:Loop"/>
        <xs:element ref="en:Li"/>
        <xs:element ref="en:Message"/>
        <xs:element ref="en:NextFrame"/>
        <xs:element ref="en:NextRow"/>
        <xs:element ref="en:Paragraph"/>
        <xs:element ref="en:PlaceObject"/>
        <xs:element ref="en:ProcessNode"/>
        <xs:element ref="en:SaveXML"/>
        <xs:element ref="en:SetVariable"/>
        <xs:element ref="en:Switch"/>
        <xs:element ref="en:Td"/>
        <xs:element ref="en:Tr"/>
        <xs:element ref="en:Until"/>
        <xs:element ref="en:Value"/>
        <xs:element ref="en:While"/>
      </xs:choice>
      <xs:attribute name="select" use="required">
        <xs:annotation>
          <xs:documentation>Die Anzahl der Schleifendurchläufe. Muss eine Zahl oder in eine Zahl konvertierbar sein.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="variable">
        <xs:annotation>
          <xs:documentation>Wenn angegeben, wird die Nummer des Schleifendurchlaufs in dieser Variablen gespeichert, ansonsten in _loopcounter.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Message">
    <xs:annotation>
      <xs:documentation>Gibt eine Textmeldung auf der Konsole und in der Protokolldatei aus.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:Value"/>
        <xs:element ref="en:Element"/>
      </xs:choice>
      <xs:attribute name="select">
        <xs:annotation>
          <xs:documentation>Inhalt der Nachricht. Alternativ dazu: Kindelemente Wert innerhalb des Elements »Message«</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="type">
        <xs:annotation>
          <xs:documentation>Der Typ der Nachricht.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="error">
              <xs:annotation>
                <xs:documentation>Fehler ausgeben.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="warning">
              <xs:annotation>
                <xs:documentation>Warnung ausgeben.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="debug">
              <xs:annotation>
                <xs:documentation>Debug-Nachricht ausgeben.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="notice">
              <xs:annotation>
                <xs:documentation>Information ausgeben (Voreinstellung).</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Layout">
    <xs:annotation>
      <xs:documentation>Das Layout-Element ist das Wurzelelement im Layoutregelwerk.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:sequence maxOccurs="unbounded">
        <xs:element minOccurs="0" ref="en:DefineColor"/>
        <xs:element minOccurs="0" ref="en:DefineMasterPage"/>
        <xs:element minOccurs="0" ref="en:Function"/>
        <xs:element minOccurs="0" ref="en:Message"/>
        <xs:element minOccurs="0" ref="en:Options"/>
        <xs:element minOccurs="0" ref="en:PDFOptions"/>
        <xs:element minOccurs="0" ref="en:PageFormat"/>
        <xs:element minOccurs="0" ref="en:Record"/>
        <xs:element minOccurs="0" ref="en:Section"/>
        <xs:element minOccurs="0" ref="en:SetGrid"/>
        <xs:element minOccurs="0" ref="en:SetVariable"/>
        <xs:element minOccurs="0" ref="en:StyleSheet"/>
        <xs:element minOccurs="0" ref="en:Trace"/>
        <xs:element minOccurs="0" ref="en:Layout"/>
      </xs:sequence>
      <xs:attribute name="version">
        <xs:annotation>
          <xs:documentation>Gibt die minimale Version des Publishers an. Format: 1.6.13. Die letzten Ziffern können weggelassen werden. Falls die erste oder die zweite Ziffer der Versionsangabe unterschiedlich ist, wird eine Warnung ausgegeben.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Mark">
    <xs:annotation>
      <xs:documentation>Setzt eine unsichtbare Markierung in die Ausgabe. Das ist hilfreich, um die Seitenzahl zu bestimmen, auf der die Marke gelandet ist.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:attribute name="append">
        <xs:annotation>
          <xs:documentation>Wenn 'yes', dann wird die aktuelle Seitenzahl an den letzten Wert angehängt (mit Komma separiert). Nützlich, um Seitenzahlen wie S. 3-5 im Index zu erstellen. Voreinstellung ist nein.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes">
              <xs:annotation>
                <xs:documentation>Die Seitenzahl an die vorherigen Werte anhängen.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="no">
              <xs:annotation>
                <xs:documentation>Den vorherigen Wert ersetzen.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="select" use="required">
        <xs:annotation>
          <xs:documentation>Der Name des Markers, der gesetzt wird.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="shiftup">
        <xs:annotation>
          <xs:documentation>Verschiebe die Position des Hyperlink-Ankers um diesen Betrag.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="pdftarget">
        <xs:annotation>
          <xs:documentation>Setze ein PDF-Ziel, das mit A referenziert werden kann.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes"/>
            <xs:enumeration value="no"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="NextFrame">
    <xs:annotation>
      <xs:documentation>Schaltet auf den nächsten freien Rahmen eines Platzierungsbereichs um.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:attribute name="area" use="required">
        <xs:annotation>
          <xs:documentation>Name des Platzierungsbereich, in dem der nächste Rahmen gesucht werden soll.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="NextRow">
    <xs:annotation>
      <xs:documentation>Der virtuelle Cursor wird auf die nächste freie Zeile gesetzt.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:attribute name="area">
        <xs:annotation>
          <xs:documentation>Name des Bereichs, in dem der Cursor bewegt wird.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="row">
        <xs:annotation>
          <xs:documentation>Zeile für den virtuellen Cursor. Wird keine Zeile angegeben, dann sucht sich der Publisher selbständig eine freie Zeile (ggf. auf einer neuen Seite oder in einem neuen Platzierungsrahmen).</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="rows">
        <xs:annotation>
          <xs:documentation>Anzahl der Zeilen, die frei gehalten werden sollen. Vorgabe: 1.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Ol">
    <xs:annotation>
      <xs:documentation>Erzeugt eine nummerierte Aufzählungsliste wie in HTML</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:Li"/>
        <xs:element ref="en:ForAll"/>
      </xs:choice>
      <xs:attribute name="class">
        <xs:annotation>
          <xs:documentation>CSS Klasse für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="id">
        <xs:annotation>
          <xs:documentation>CSS id für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="style">
        <xs:annotation>
          <xs:documentation>CSS Stil für dieses Element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Options">
    <xs:annotation>
      <xs:documentation>Setzt Publisher-spezifische Optionen.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:attribute name="bleed">
        <xs:annotation>
          <xs:documentation>Die Größe des Anschnitts (bleed). Voreinstellung ist 0mm.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="cutmarks">
        <xs:annotation>
          <xs:documentation>Beschnittmarken (crop marks) werden ausgegeben. Der Abstand der Schnittmarken vom gedachten Mittelpunkt ergibt sich durch die Beschnittzugabe, mindestens beträgt sie jedoch 5pt. Die Länge der Schnittmarke ist 1cm. Voreinstellung ist nein, d.h. es werden keine Schnittmarken ausgegeben.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes">
              <xs:annotation>
                <xs:documentation>Beschnittmarken anzeigen.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="no">
              <xs:annotation>
                <xs:documentation>Beschnittmarken nicht anzeigen (Voreinstellung).</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="features">
        <xs:annotation>
          <xs:documentation>Eine kommaseparierte Liste mit OpenType Features wie +kern,-liga. Wird als Voreinstellung für alle Absätze benutzt.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="mainlanguage">
        <xs:annotation>
          <xs:documentation>Die Sprache (Silbentrennung und Darstellung), die im Text benutzt wird, wenn keine andere Sprache angegeben ist. Sie kann global über die Kommandozeile gesteuert werden oder für jeden Paragraph und TextBlock einzeln.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:union>
            <xs:simpleType>
              <xs:restriction base="xs:string">
                <xs:pattern value="\{.+\}"/>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:string">
                <xs:pattern value="--|bg|ca|cs|cy|da|de|el|en|en_GB|en_US|eo|es|et|eu|fi|fr|ga|gl|grc|gu|hi|hr|hu|hy|id|is|it|kn|ku|lt|lv|ml|nb|nl|nn|pl|pt|ro|ru|sc|sk|sl|sr|sv|tr|uk|zh"/>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="Ancient Greek">
                  <xs:annotation>
                    <xs:documentation>Altgriechisch</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="Armenian">
                  <xs:annotation>
                    <xs:documentation>Armenisch</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="Bahasa Indonesia">
                  <xs:annotation>
                    <xs:documentation>Indonesisch</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="Basque">
                  <xs:annotation>
                    <xs:documentation>Baskisch</xs:documentation>
                  </xs:annotation>
                </xs:enumeration>
              </xs:restriction>
            </xs:simpleType>
            <xs:simpleType>
              <xs:restriction base="xs:token">
