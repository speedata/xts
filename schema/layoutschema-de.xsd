    </xs:complexType>
  </xs:element>
  <xs:element name="h5">
    <xs:complexType>
      <xs:complexContent>
        <xs:extension base="en:html">
          <xs:attributeGroup ref="en:htmlclassidstyle"/>
        </xs:extension>
      </xs:complexContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="h6">
    <xs:complexType>
      <xs:complexContent>
        <xs:extension base="en:html">
          <xs:attributeGroup ref="en:htmlclassidstyle"/>
        </xs:extension>
      </xs:complexContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="i" type="en:html"/>
  <xs:element name="img">
