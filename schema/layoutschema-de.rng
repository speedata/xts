                            <optional>
                                <ref name="e_ProcessNode"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SaveXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SetVariable"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Switch"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Td"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Tr"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Until"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                            <optional>
                                <ref name="e_While"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Function">
        <element name="Function">
            <a:documentation>Definiere eine Funktion</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="name">
                            <a:documentation>Der Name der Funktion (mit Namensraum-Präfix)</a:documentation>
                        </attribute>
                    </optional>
                    <zeroOrMore>
                        <ref name="e_Param"></ref>
                    </zeroOrMore>
                    <oneOrMore>
                        <optional>
                            <ref name="e_ClearPage"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Column"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Columns"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ForAll"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Slate"></ref>
                        </optional>
                        <optional>
                            <ref name="e_LoadXML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Loop"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Message"></ref>
                        </optional>
                        <optional>
                            <ref name="e_NextFrame"></ref>
                        </optional>
                        <optional>
                            <ref name="e_NextRow"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PlaceObject"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ProcessNode"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SaveXML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetVariable"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Switch"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Value"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Slate">
        <element name="Slate">
            <a:documentation>Erzeugt einen virtuellen Bereich (Slate), in dem Elemente platziert werden können. Wie bei einer Zaubertafel wird der Inhalt zunächst unsichtbar aufgebaut und dann mit PlaceObject auf der Seite platziert.</a:documentation>
            <interleave>
                <group>
                    <attribute name="name">
                        <a:documentation>Der Name des anzulegenden Slates.</a:documentation>
                    </attribute>
                    <ref name="e_Contents"></ref>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_SlateContents">
        <element name="SlateContents">
            <a:documentation>Fügt den Inhalt eines zuvor erstellten Slates ein.</a:documentation>
            <attribute name="name">
                <a:documentation>Name des Slates, dessen Inhalt eingefügt werden soll.</a:documentation>
            </attribute>
            <empty></empty>
        </element>
    </define>
    <define name="e_I">
        <element name="I">
            <a:documentation>Schaltet auf »Kursiv« um.</a:documentation>
            <interleave>
                <group>
                    <zeroOrMore>
                        <choice>
                            <ref name="e_A"></ref>
                            <ref name="e_Action"></ref>
                            <ref name="e_B"></ref>
                            <ref name="e_Br"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_I"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_U"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                            <ref name="e_CopyOf"></ref>
                            <ref name="e_Span"></ref>
                        </choice>
                    </zeroOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Image">
        <element name="Image">
            <a:documentation>Bindet eine externe Grafik ein. Erlaubte Grafikformate sind PDF (.pdf), PNG (.png) und JPEG (.jpg). Siehe unten für die Einschränkung eingebundener PDF-Dateien.</a:documentation>
            <optional>
                <attribute name="href">
                    <a:documentation>Dateiname des Bildes. Kann entweder eine Datei im Suchpfad sein, ein absoluter Dateiname, ein file-URI-Schema (z.B. file:///pfad/zum/bild.pdf) oder eine Quelle im Web (http/https). Mit placeholder://BxH (z.B. placeholder://200x150) wird ein Platzhalterbild mit den angegebenen Maßen in PDF-Punkten erzeugt.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="height">
                    <a:documentation>Bildhöhe. Angabe in der Form &#39;auto&#39; (Voreinstellung, natürliche Bildbreite), Längenangabe wie &#39;4cm&#39; oder Zahl (Anzahl von Rasterspalten)</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="page">
                    <a:documentation>Die Seitenzahl aus dem PDF. Voreinstellung ist 1.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="maxwidth">
                    <a:documentation>Die maximale Breite des Bilds. Nur, wenn clip=&#34;no&#34;. Angabe in absoluten Längen, Rasterzellen oder »100%« für volle Breite.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="maxheight">
                    <a:documentation>Die maximale Breite des Bilds. Nur, wenn clip=&#34;no&#34;. Angabe in absoluten Längen oder Anzahl Rasterzellen.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="minwidth">
                    <a:documentation>Die minimale Breite des Bilds. Nur, wenn clip=&#34;no&#34;. Angabe in absoluten Längen, Rasterzellen oder »100%« für volle Breite.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="minheight">
                    <a:documentation>Die minimale Breite des Bilds. Nur, wenn clip=&#34;no&#34;. Angabe in absoluten Längen oder Anzahl Rasterzellen.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="stretch">
                    <a:documentation>Dehnt das Bild bis eine der Angaben von maxheight und maxwidth erreich ist. Hilfreich um Bilder so groß wie möglich aber innerhalb gewisser Grenzen anzeigen zu lassen.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <value>no</value>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="visiblebox">
                    <a:documentation>Die PDF-Box, die den sichtbaren Bereich angibt des eingebundenen PDFs angibt. Voreinstellung ist »cropbox«.</a:documentation>
                    <choice>
                        <value>artbox</value>
                        <a:documentation>Nutze die artbox als sichtbaren Bereich. Diese Box ist normalerweise in PDF-Dateien nicht enthalten.</a:documentation>
                        <value>bleedbox</value>
                        <a:documentation>Nutze die bleedbox des eingebundenen PDFs.</a:documentation>
                        <value>cropbox</value>
                        <a:documentation>Nutze die cropbox der eingebundenen PDF-Datei (Voreinstellung).</a:documentation>
                        <value>mediabox</value>
                        <a:documentation>Nutze die mediabox der eingebundenen PDF-Datei. Das ist die größte Box.</a:documentation>
                        <value>trimbox</value>
                        <a:documentation>Nutze die trimbox der eingebundenen PDF-Datei. Die trimbox ist die Papiergröße. Beispielsweise hat die trimbox eines A4-PDFs die Größe 210mm x 297mm.</a:documentation>
                        <data type="string">
                            <param name="pattern">\{.+\}</param>
                        </data>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="width">
                    <a:documentation>Bildbreite. Angabe in der Form &#39;auto&#39; (Voreinstellung, natürliche Bildbreite), &#39;100%&#39; (Breite des aktuellen Platzierungsbereichs), Längenangabe wie &#39;4cm&#39; oder Zahl (Anzahl von Rasterspalten)</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_LoadXML">
        <element name="LoadXML">
            <a:documentation>Lädt eine Datensatzdatei, die in einem vorherigen Durchlauf des Publishers erzeugt wurde (Attribut name), oder eine reguläre XML-Datei (Attribut href). Die »normale« Verarbeitung des Layoutregelwerks wird unterbrochen und mit dem Inhalt der Datensatzdatei fortgeführt. Nachdem die Verarbeitung der neu geladenen Datensatzdatei beendet ist, wird die Verarbeitung des Layoutregelwerks mit dem ursprünglichen Datensatz fortgesetzt. Eine ausführlichere Erläuterung findet sich im Abschnitt über automatisch generierte Verzeichnisse.</a:documentation>
            <optional>
                <attribute name="name">
                    <a:documentation>Name der Dateisatzdatei. Beispiel: toc</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="href">
                    <a:documentation>Name der XML-Datei, die geladen werden soll. Beispiel: meinedatei.xml.</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Li">
        <element name="Li">
            <a:documentation>Listeneintrag in einer Aufzählungsliste (mit Aufzählungspunkten oder nummerierten Punkten).</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS Klasse für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS Stil für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <zeroOrMore>
                        <choice>
                            <ref name="e_A"></ref>
                            <ref name="e_Action"></ref>
                            <ref name="e_B"></ref>
                            <ref name="e_Br"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_I"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_U"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                            <ref name="e_CopyOf"></ref>
                            <ref name="e_Span"></ref>
                        </choice>
                    </zeroOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Loop">
        <element name="Loop">
            <a:documentation>Wiederhole den Inhalt dieses Elements mehrfach.</a:documentation>
            <interleave>
                <group>
                    <attribute name="select">
                        <a:documentation>Die Anzahl der Schleifendurchläufe. Muss eine Zahl oder in eine Zahl konvertierbar sein.</a:documentation>
                    </attribute>
                    <optional>
                        <attribute name="variable">
                            <a:documentation>Wenn angegeben, wird die Nummer des Schleifendurchlaufs in dieser Variablen gespeichert, ansonsten in _loopcounter.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Column"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ClearPage"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                            <optional>
                                <ref name="e_HTML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_LoadXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Loop"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Li"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Message"></ref>
                            </optional>
                            <optional>
                                <ref name="e_NextFrame"></ref>
                            </optional>
                            <optional>
                                <ref name="e_NextRow"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Paragraph"></ref>
                            </optional>
                            <optional>
                                <ref name="e_PlaceObject"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ProcessNode"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SaveXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SetVariable"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Switch"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Td"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Tr"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Until"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                            <optional>
                                <ref name="e_While"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Message">
        <element name="Message">
            <a:documentation>Gibt eine Textmeldung auf der Konsole und in der Protokolldatei aus.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="select">
                            <a:documentation>Inhalt der Nachricht. Alternativ dazu: Kindelemente Wert innerhalb des Elements »Message«</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="type">
                            <a:documentation>Der Typ der Nachricht.</a:documentation>
                            <choice>
                                <value>error</value>
                                <a:documentation>Fehler ausgeben.</a:documentation>
                                <value>warning</value>
                                <a:documentation>Warnung ausgeben.</a:documentation>
                                <value>debug</value>
                                <a:documentation>Debug-Nachricht ausgeben.</a:documentation>
                                <value>notice</value>
                                <a:documentation>Information ausgeben (Voreinstellung).</a:documentation>
                            </choice>
                        </attribute>
                    </optional>
                    <interleave>
                        <optional>
                            <oneOrMore>
                                <ref name="e_Value"></ref>
                            </oneOrMore>
                        </optional>
                        <optional>
                            <oneOrMore>
                                <ref name="e_Element"></ref>
                            </oneOrMore>
                        </optional>
                    </interleave>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Layout">
        <element name="Layout">
            <a:documentation>Das Layout-Element ist das Wurzelelement im Layoutregelwerk.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="version">
                            <a:documentation>Gibt die minimale Version des Publishers an. Format: 1.6.13. Die letzten Ziffern können weggelassen werden. Falls die erste oder die zweite Ziffer der Versionsangabe unterschiedlich ist, wird eine Warnung ausgegeben.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <optional>
                            <ref name="e_DefineColor"></ref>
                        </optional>
                        <optional>
                            <ref name="e_DefineMasterPage"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Function"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Message"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Options"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PDFOptions"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PageFormat"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Record"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Section"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetGrid"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetVariable"></ref>
                        </optional>
                        <optional>
                            <ref name="e_StyleSheet"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Trace"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Layout"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Mark">
        <element name="Mark">
            <a:documentation>Setzt eine unsichtbare Markierung in die Ausgabe. Das ist hilfreich, um die Seitenzahl zu bestimmen, auf der die Marke gelandet ist.</a:documentation>
            <optional>
                <attribute name="append">
                    <a:documentation>Wenn &#39;yes&#39;, dann wird die aktuelle Seitenzahl an den letzten Wert angehängt (mit Komma separiert). Nützlich, um Seitenzahlen wie S. 3-5 im Index zu erstellen. Voreinstellung ist nein.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Die Seitenzahl an die vorherigen Werte anhängen.</a:documentation>
                        <value>no</value>
                        <a:documentation>Den vorherigen Wert ersetzen.</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <attribute name="select">
                <a:documentation>Der Name des Markers, der gesetzt wird.</a:documentation>
            </attribute>
            <optional>
                <attribute name="shiftup">
                    <a:documentation>Verschiebe die Position des Hyperlink-Ankers um diesen Betrag.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="pdftarget">
                    <a:documentation>Setze ein PDF-Ziel, das mit A referenziert werden kann.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <value>no</value>
                    </choice>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_NextFrame">
        <element name="NextFrame">
            <a:documentation>Schaltet auf den nächsten freien Rahmen eines Platzierungsbereichs um.</a:documentation>
            <attribute name="area">
                <a:documentation>Name des Platzierungsbereich, in dem der nächste Rahmen gesucht werden soll.</a:documentation>
            </attribute>
            <empty></empty>
        </element>
    </define>
    <define name="e_NextRow">
        <element name="NextRow">
            <a:documentation>Der virtuelle Cursor wird auf die nächste freie Zeile gesetzt.</a:documentation>
            <optional>
                <attribute name="area">
                    <a:documentation>Name des Bereichs, in dem der Cursor bewegt wird.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="row">
                    <a:documentation>Zeile für den virtuellen Cursor. Wird keine Zeile angegeben, dann sucht sich der Publisher selbständig eine freie Zeile (ggf. auf einer neuen Seite oder in einem neuen Platzierungsrahmen).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="rows">
                    <a:documentation>Anzahl der Zeilen, die frei gehalten werden sollen. Vorgabe: 1.</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Ol">
        <element name="Ol">
            <a:documentation>Erzeugt eine nummerierte Aufzählungsliste wie in HTML</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS Klasse für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS Stil für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Li"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Options">
        <element name="Options">
            <a:documentation>Setzt Publisher-spezifische Optionen.</a:documentation>
            <optional>
                <attribute name="bleed">
                    <a:documentation>Die Größe des Anschnitts (bleed). Voreinstellung ist 0mm.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="cutmarks">
                    <a:documentation>Beschnittmarken (crop marks) werden ausgegeben. Der Abstand der Schnittmarken vom gedachten Mittelpunkt ergibt sich durch die Beschnittzugabe, mindestens beträgt sie jedoch 5pt. Die Länge der Schnittmarke ist 1cm. Voreinstellung ist nein, d.h. es werden keine Schnittmarken ausgegeben.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Beschnittmarken anzeigen.</a:documentation>
                        <value>no</value>
                        <a:documentation>Beschnittmarken nicht anzeigen (Voreinstellung).</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="features">
                    <a:documentation>Eine kommaseparierte Liste mit OpenType Features wie +kern,-liga. Wird als Voreinstellung für alle Absätze benutzt.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="mainlanguage">
                    <a:documentation>Die Sprache (Silbentrennung und Darstellung), die im Text benutzt wird, wenn keine andere Sprache angegeben ist. Sie kann global über die Kommandozeile gesteuert werden oder für jeden Paragraph und TextBlock einzeln.</a:documentation>
                    <choice>
                        <data type="string">
                            <param name="pattern">\{.+\}</param>
                        </data>
                        <data type="string">
                            <param name="pattern">--|bg|ca|cs|cy|da|de|el|en|en_GB|en_US|eo|es|et|eu|fi|fr|ga|gl|grc|gu|hi|hr|hu|hy|id|is|it|kn|ku|lt|lv|ml|nb|nl|nn|pl|pt|ro|ru|sc|sk|sl|sr|sv|tr|uk|zh</param>
                        </data>
                        <value>Ancient Greek</value>
                        <a:documentation>Altgriechisch</a:documentation>
                        <value>Armenian</value>
                        <a:documentation>Armenisch</a:documentation>
                        <value>Bahasa Indonesia</value>
                        <a:documentation>Indonesisch</a:documentation>
                        <value>Basque</value>
                        <a:documentation>Baskisch</a:documentation>
                        <value>Bulgarian</value>
                        <a:documentation>Bulgarisch (lateinisches Alphabet)</a:documentation>
                        <value>Catalan</value>
                        <a:documentation>Katalanisch</a:documentation>
                        <value>Chinese</value>
                        <a:documentation>Auf chinsische Sprache umschalten.</a:documentation>
                        <value>Croatian</value>
                        <a:documentation>Kroatisch</a:documentation>
                        <value>Czech</value>
                        <a:documentation>Tschechisch</a:documentation>
                        <value>Danish</value>
                        <a:documentation>Dänisch</a:documentation>
                        <value>Dutch</value>
                        <a:documentation>Niederländisch</a:documentation>
                        <value>English (Great Britain)</value>
                        <a:documentation>GB-Englisch</a:documentation>
                        <value>English (USA)</value>
                        <a:documentation>US-Englisch</a:documentation>
                        <value>Esperanto</value>
                        <a:documentation>Esperanto</a:documentation>
                        <value>Estonian</value>
                        <a:documentation>Estnisch</a:documentation>
                        <value>Finnish</value>
                        <a:documentation>Finnisch</a:documentation>
                        <value>French</value>
                        <a:documentation>Französisch</a:documentation>
                        <value>Galician</value>
                        <a:documentation>Galicisch</a:documentation>
                        <value>German</value>
                        <a:documentation>Deutsch</a:documentation>
                        <value>Greek</value>
                        <a:documentation>Neugriechisch</a:documentation>
                        <value>Gujarati</value>
                        <a:documentation>Gujarati</a:documentation>
                        <value>Hungarian</value>
                        <a:documentation>Ungarisch</a:documentation>
                        <value>Hindi</value>
                        <a:documentation>Hindi</a:documentation>
                        <value>Icelandic</value>
                        <a:documentation>Isländisch</a:documentation>
                        <value>Irish</value>
                        <a:documentation>Irisch</a:documentation>
                        <value>Italian</value>
                        <a:documentation>Italienisch</a:documentation>
                        <value>Kannada</value>
                        <a:documentation>Kanaresisch</a:documentation>
                        <value>Kurmanji</value>
                        <a:documentation>Kurmandschi</a:documentation>
                        <value>Latvian</value>
                        <a:documentation>Lettisch</a:documentation>
                        <value>Lithuanian</value>
                        <a:documentation>Litauisch</a:documentation>
                        <value>Malayalam</value>
                        <a:documentation>Malayalam</a:documentation>
                        <value>Norwegian Bokmål</value>
                        <a:documentation>Norwegisch (Bokmål).</a:documentation>
                        <value>Norwegian Nynorsk</value>
                        <a:documentation>Norwegisch (Nynorsk).</a:documentation>
                        <value>Other</value>
                        <a:documentation>Auf keine der anderen Sprachen umschalten. Hilfreich bei Darstellungsproblemen.</a:documentation>
                        <value>Polish</value>
                        <a:documentation>Polnisch</a:documentation>
                        <value>Portuguese</value>
                        <a:documentation>Portugiesisch</a:documentation>
                        <value>Romanian</value>
                        <a:documentation>Rumänisch</a:documentation>
                        <value>Russian</value>
                        <a:documentation>Russisch</a:documentation>
                        <value>Serbian</value>
                        <a:documentation>Serbisch</a:documentation>
                        <value>Serbian (cyrillic)</value>
                        <a:documentation>Serbisch (kyrillische Buchstaben).</a:documentation>
                        <value>Slovak</value>
                        <a:documentation>Slowakisch</a:documentation>
                        <value>Slovenian</value>
                        <a:documentation>Slowenisch</a:documentation>
                        <value>Spanish</value>
                        <a:documentation>Spanisch</a:documentation>
                        <value>Swedish</value>
                        <a:documentation>Schwedisch</a:documentation>
                        <value>Turkish</value>
                        <a:documentation>Türkisch</a:documentation>
                        <value>Ukrainian</value>
                        <a:documentation>Ukrainisch</a:documentation>
                        <value>Welsh</value>
                        <a:documentation>Walisisch</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Otherwise">
        <element name="Otherwise">
            <a:documentation>Zweig, der bei Switch ausgeführt wird, wenn kein Case wahr ist.</a:documentation>
            <interleave>
                <group>
                    <oneOrMore>
                        <optional>
                            <ref name="e_Column"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ClearPage"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ForAll"></ref>
                        </optional>
                        <optional>
                            <ref name="e_HTML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_LoadXML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Loop"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Li"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Message"></ref>
                        </optional>
                        <optional>
                            <ref name="e_NextFrame"></ref>
                        </optional>
                        <optional>
                            <ref name="e_NextRow"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Paragraph"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PlaceObject"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ProcessNode"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SaveXML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetVariable"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Switch"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Td"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Tr"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Until"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Value"></ref>
                        </optional>
                        <optional>
                            <ref name="e_While"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_PageFormat">
        <element name="PageFormat">
            <a:documentation>Legt die Größe des Ausgabemediums (z.B. DIN A4) fest. Voreinstellung ist eine Breite von 210mm und eine Höhe von 297mm.</a:documentation>
            <attribute name="height">
                <a:documentation>Höhe des Ausgabemediums.</a:documentation>
            </attribute>
            <attribute name="width">
                <a:documentation>Breite des Ausgabemediums.</a:documentation>
            </attribute>
            <empty></empty>
        </element>
    </define>
    <define name="e_Paragraph">
        <element name="Paragraph">
            <a:documentation>Erzeugt einen Absatz innerhalb eines TextBlocks.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS Klasse für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS Stil-Angaben für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <zeroOrMore>
                        <choice>
                            <ref name="e_A"></ref>
                            <ref name="e_Action"></ref>
                            <ref name="e_B"></ref>
                            <ref name="e_Br"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_I"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_U"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                            <ref name="e_CopyOf"></ref>
                            <ref name="e_Span"></ref>
                        </choice>
                    </zeroOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Param">
        <element name="Param">
            <a:documentation>Lege einen Parameter für eine Funktionsdefinition fest.</a:documentation>
            <optional>
                <attribute name="name">
                    <a:documentation>Der Name des Parameters</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_PDFOptions">
        <element name="PDFOptions">
            <a:documentation>Setze PDF Optionen</a:documentation>
            <optional>
                <attribute name="author">
                    <a:documentation>Legt den Autor des Dokuments fest</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="creator">
                    <a:documentation>Legt die Anwendung des Dokuments fest</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="displaymode">
                    <a:documentation>Wähle den PDF-Anzeigemodes (vornehmlich beim Adobe Acrobat).</a:documentation>
                    <choice>
                        <value>attachments</value>
                        <a:documentation>Zeige die Anhänge.</a:documentation>
                        <value>bookmarks</value>
                        <a:documentation>Zeige die Lesezeichen (sofern das Dokument Lesezeichen enthält).</a:documentation>
                        <value>fullscreen</value>
                        <a:documentation>Öffne das Dokument im Vollbildmodus.</a:documentation>
                        <value>none</value>
                        <a:documentation>Keine besondere Anzeigeart wählen.</a:documentation>
                        <value>thumbnails</value>
                        <a:documentation>Die Vorschaubilder zeigen.</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="duplex">
                    <a:documentation>Setze PDF Anzeigeprogramm auf einseitigen oder doppelseitigen Druck. Voreinstellung: leer.</a:documentation>
                    <choice>
                        <value>simplex</value>
                        <a:documentation>Eine Seite je Blatt</a:documentation>
                        <value>duplexflipshortedge</value>
                        <a:documentation>Beidseitig und an kurzer Kante umblättern</a:documentation>
                        <value>duplexfliplongedge</value>
                        <a:documentation>Beidseitig und an langer Kante umblättern</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="picktraybypdfsize">
                    <a:documentation>Auswahlfeld im PDF-Viewer »Papierquelle gemäß PDF-Seitengröße auswählen«.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Checkbox aktivieren</a:documentation>
                        <value>no</value>
                        <a:documentation>Checkbox deaktivieren</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="printscaling">
                    <a:documentation>Soll der Drucker die Seiten skalieren?</a:documentation>
                    <choice>
                        <value>appdefault</value>
                        <a:documentation>Voreinstellung des PDF-Viewers benutzen</a:documentation>
                        <value>none</value>
                        <a:documentation>Keine Seitenskalierung</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="showhyperlinks">
                    <a:documentation>Zeige Hyperlinks im Adobe Acrobat und ggf anderen PDF-Anzeigeprogrammen.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <value>no</value>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="subject">
                    <a:documentation>Legt den Betreff (subject) des Dokuments fest</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="title">
                    <a:documentation>Legt den Titel des Dokuments fest</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_PlaceObject">
        <element name="PlaceObject">
            <a:documentation>Gibt ein rechteckiges Objekt (Bild, Tabelle, Box oder TextBlock) aus.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="allocate">
                            <a:documentation>Bestimmt, ob im Raster der Platz für das Objekt als »belegt« markiert wird. Bei allocate=&#34;no&#34; wird auch die aktuelle Zeile im Raster nicht verändert.</a:documentation>
                            <choice>
                                <value>yes</value>
                                <a:documentation>Platz im Raster reservieren (Voreinstellung für Platzierung im Raster).</a:documentation>
                                <value>no</value>
                                <a:documentation>Bereich nicht als Belegt markieren (Voreinstellung für absolute Positionierung)</a:documentation>
                            </choice>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="area">
                            <a:documentation>Name des Platzierungsbereich, in dem das Objekt ausgegeben werden soll.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="background">
                            <a:documentation>Erzeugt einen farbigen Hintergrund für das Objekt. Das Attribut »backgroundcolor« gibt die Farbe an.</a:documentation>
                            <choice>
                                <value>yes</value>
                                <value>no</value>
                            </choice>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="backgroundcolor">
                            <a:documentation>Hintergrundfarbe wenn das Objekt mit einer Farbe hinterlegt werden soll.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="column">
                            <a:documentation>Zahl: Die Spalte im Raster, in der das Objekt ausgegeben wird. Wird die Spalte nicht angegeben, so sucht sich das System selbständig eine passende freie Zeile für das Objekt. Maßangabe: die Position von der linken Blattkante.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="frame">
                            <a:documentation>Es wird ein Rahmen um das Objekt gezeichnet.</a:documentation>
                            <choice>
                                <value>yes</value>
                                <value>no</value>
                            </choice>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="slate">
                            <a:documentation>Wenn ein Slate ausgegeben werden soll, muss der Name hier angegeben werden.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="halign">
                            <a:documentation>Wird ein Objekt ausgegeben, das kein vielfaches der Rasterbreite ist, dann gibt das Attribut die horizontale Ausrichtung an. ›left‹ beispielsweise bedeutet, dass der freie Platz rechts des Objekts bleibt. Voreinstellung ist ›left‹.</a:documentation>
                            <choice>
                                <value>left</value>
                                <a:documentation>Das Objekt wird links ausgerichtet.</a:documentation>
                                <value>right</value>
                                <a:documentation>Das Objekt wird rechts ausgerichtet.</a:documentation>
                                <data type="string">
                                    <param name="pattern">\{.+\}</param>
                                </data>
                            </choice>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="hreference">
                            <a:documentation>Bestimmt, ob die angegebene Spalte die linke oder die rechte Kante vom Objekt bezeichnet.</a:documentation>
                            <choice>
                                <value>left</value>
                                <a:documentation>Das Objekt wird in der angegebenen Spalte platziert.</a:documentation>
                                <value>center</value>
                                <a:documentation>Die angegebene Spalte bestimmt die horizontale Mitte des Objekts.</a:documentation>
                                <value>right</value>
                                <a:documentation>Das Objekt wird mit dem rechten Rand in der gegebenen Spalte am rechten Rand ausgerichtet.</a:documentation>
                                <data type="string">
                                    <param name="pattern">\{.+\}</param>
                                </data>
                            </choice>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="row">
                            <a:documentation>Zahl: Die Zeile im Raster, in der das Objekt ausgegeben wird. Wird die Zeile nicht angegeben, so sucht sich das System selbständig eine passende freie Zeile für das Objekt. Maßangabe: die Position von der oberen Blattkante.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="vreference">
                            <a:documentation>Bestimmt, ob die angegebene Zeile die obere, untere oder mittlere Kante des Objekts bezeichnet.</a:documentation>
                            <choice>
                                <value>top</value>
                                <a:documentation>Die angegebene Zeile bestimmt die obere Kante des Objekts (Voreinstellung).</a:documentation>
                                <value>middle</value>
                                <a:documentation>Die angegebene Zeile bestimmt die vertikale Mitte des Objekts.</a:documentation>
                                <value>bottom</value>
                                <a:documentation>Die angegebene Zeile bestimmt die untere Kante des Objekts.</a:documentation>
                                <data type="string">
                                    <param name="pattern">\{.+\}</param>
                                </data>
                            </choice>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Box"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Circle"></ref>
                            </optional>
                            <optional>
                                <ref name="e_HTML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Image"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Table"></ref>
                            </optional>
                            <optional>
                                <ref name="e_TextBlock"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_PositioningArea">
        <element name="PositioningArea">
            <a:documentation>Beschreibt einen Platzierungsbereich, der mehrere Platzierungsrahmen beinhalten kann. In diesen Rahmen können Elemente platziert werden</a:documentation>
            <interleave>
                <group>
                    <attribute name="name">
                        <a:documentation>Name des Platzierungsbereichs</a:documentation>
                    </attribute>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_PositioningFrame"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Switch"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_PositioningFrame">
        <element name="PositioningFrame">
            <a:documentation>Beschreibt einen rechteckigen Bereich, in dem Elemente platziert werden können. Inhalte in diesen Bereichen werden bei Platzmangel automatisch in den nächsten Rahmen desselben Bereichs platziert.</a:documentation>
            <attribute name="width">
                <a:documentation>Breite des Rahmens in Rasterkästen</a:documentation>
            </attribute>
            <attribute name="height">
                <a:documentation>Höhe des Rahmens in Rasterkästen</a:documentation>
            </attribute>
            <attribute name="row">
                <a:documentation>Erste Zeile des Rahmens</a:documentation>
            </attribute>
            <attribute name="column">
                <a:documentation>Erste Spalte des Rahmens</a:documentation>
            </attribute>
            <empty></empty>
        </element>
    </define>
    <define name="e_ProcessNode">
        <element name="ProcessNode">
            <a:documentation>Bearbeitet alle angegebenen Datensätze. Die Elemente, für die die Regeln ausgeführt werden sollen, werden mit dem Attribut select angegeben.</a:documentation>
            <attribute name="select">
                <a:documentation>Auswahl der Kindelemente, die verarbeitet werden sollen.</a:documentation>
            </attribute>
            <optional>
                <attribute name="mode">
                    <a:documentation>Name des Modus. Dieser muss bei Record exakt übereinstimmen. Damit ist es möglich für dasselbe Element unterschiedliche Regeln aufzurufen.</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Record">
        <element name="Record">
            <a:documentation>Enthält die Anweisungen, die ausgeführt werden, wenn ein Datenelement dem angegebenen Match-Ausdruck entspricht. Der Record, der auf das Wurzelelement passt, wird automatisch aufgerufen; alle weiteren Datensätze müssen über ProcessNode verarbeitet werden. Match-Ausdrücke unterstützen XPath-Prädikate für bedingtes Matching (ähnlich wie XSLT-Template-Matching).</a:documentation>
            <interleave>
                <group>
                    <attribute name="match">
                        <a:documentation>Ein XPath-Match-Ausdruck. Dies kann ein einfacher Elementname sein (z.B. data) oder ein Elementname gefolgt von einem XPath-Prädikat in eckigen Klammern (z.B. item[@type=&#39;invoice&#39;] oder item[not(@hidden=&#39;true&#39;)]). Wenn mehrere Records auf dasselbe Element passen, haben Records mit Prädikaten Vorrang vor solchen ohne. Bei mehreren passenden Records mit Prädikaten gewinnt der zuletzt definierte.</a:documentation>
                    </attribute>
                    <optional>
                        <attribute name="mode">
                            <a:documentation>Name des Modus der mit dem in ProcessNode übereinstimmt.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <optional>
                            <ref name="e_ClearPage"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ForAll"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Slate"></ref>
                        </optional>
                        <optional>
                            <ref name="e_LoadXML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Loop"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Message"></ref>
                        </optional>
                        <optional>
                            <ref name="e_NextFrame"></ref>
                        </optional>
                        <optional>
                            <ref name="e_NextRow"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PlaceObject"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ProcessNode"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SaveXML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetVariable"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Switch"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Until"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Value"></ref>
                        </optional>
                        <optional>
                            <ref name="e_While"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_SaveXML">
        <element name="SaveXML">
            <a:documentation>Speichert eine XML-Datei auf Festplatte. Diese Datei muss als Kindelement hierarchische Struktur, zum Beispiel aus den Befehlen Element und Attribut enthalten, wahlweise zusammengesetzt durch Variablen. Eine ausführlichere Erläuterung findet sich im Abschnitt über automatisch generierte Verzeichnisse.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="href">
                            <a:documentation>Name der Dateisatzdatei. Beispiel: toc.xml</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="name">
                            <a:documentation>Name der Dateisatzdatei. Beispiel: toc</a:documentation>
                        </attribute>
                    </optional>
                    <attribute name="elementname">
                        <a:documentation>Name des Wurzelelements, das erzeugt wird.</a:documentation>
                    </attribute>
                    <optional>
                        <attribute name="select">
                            <a:documentation>Alternativ zur Angabe des Datensatzes im Kindelement.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <optional>
                            <ref name="e_Element"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ForAll"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Loop"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Value"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Section">
        <element name="Section">
            <a:documentation>Ein Gliederungselement zur Organisation des Layouts. Hat keinen Einfluss auf die Ausgabe.</a:documentation>
            <interleave>
                <group>
                    <attribute name="name">
                        <a:documentation>Name dieses Abschnitts (nur zur Dokumentation).</a:documentation>
                    </attribute>
                    <oneOrMore>
                        <optional>
                            <ref name="e_DefineColor"></ref>
                        </optional>
                        <optional>
                            <ref name="e_DefineMasterPage"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Function"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Message"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Options"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PDFOptions"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PageFormat"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Record"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Section"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetGrid"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetVariable"></ref>
                        </optional>
                        <optional>
                            <ref name="e_StyleSheet"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Trace"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_SetGrid">
        <element name="SetGrid">
            <a:documentation>Setzt die Größe und Höhe eines Rasterkästchens. In dem Seitenraster können Elemente platziert werden.</a:documentation>
            <optional>
                <attribute name="width">
                    <a:documentation>Breite einer Rasterzelle. Entweder width oder nx benutzen, nicht beide.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="height">
                    <a:documentation>Höhe einer Rasterzelle. Entweder höhe oder ny angeben, nicht beide.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="nx">
                    <a:documentation>Anzahl der Rasterzellen in horizontaler Richtung. Entweder nx oder width angeben.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="ny">
                    <a:documentation>Gibt die Anzahl der Rasterzellen in vertikaler Richtung an. Entweder ny oder höhe angeben.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="dx">
                    <a:documentation>Abstand zwischen zwei Rasterzellen (horizontal)</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="dy">
                    <a:documentation>Abstand zwischen zwei Rasterzellen (horizontal)</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
      <sch:pattern>
        <sch:rule context="t:SetVariable">
        <sch:assert test="not(  not(empty(@select)) and node()  )">SetVariable: entweder Attribut select benutzen _oder_ Kindelemente, aber nicht beides.</sch:assert>
      </sch:rule>
      </sch:pattern>
    
    <define name="e_SetVariable">
        <element name="SetVariable">
            <a:documentation>Weist einer Variablen einen Wert zu. Der Wert kann aus mehreren Elementen bestehen (siehe zweites Beispiel).</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="select">
                            <a:documentation>Inhalt, der der Variablen zugewiesen wird.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="trace">
                            <a:documentation>Zeige Informationen über die Zuweisung in der Logdatei.</a:documentation>
                            <choice>
                                <value>yes</value>
                                <a:documentation>Zeige Informationen.</a:documentation>
                                <value>no</value>
                                <a:documentation>Zeige keine Informationen (Voreinstellung).</a:documentation>
                            </choice>
                        </attribute>
                    </optional>
                    <attribute name="variable">
                        <a:documentation>Name der Variablen, der etwas zugewiesen werden soll.</a:documentation>
                    </attribute>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_CopyOf"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Element"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Paragraph"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Table"></ref>
                            </optional>
                            <optional>
                                <ref name="e_TextBlock"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Until"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                            <optional>
                                <ref name="e_While"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Span">
        <element name="Span">
            <a:documentation>Text mit Style-Optionen umgeben.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS Klasse für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>Setze den CSS-Stil.</a:documentation>
                        </attribute>
                    </optional>
                    <zeroOrMore>
                        <choice>
                            <ref name="e_A"></ref>
                            <ref name="e_Action"></ref>
                            <ref name="e_B"></ref>
                            <ref name="e_Br"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_I"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_U"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                            <ref name="e_CopyOf"></ref>
                            <ref name="e_Span"></ref>
                        </choice>
                    </zeroOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Switch">
        <element name="Switch">
            <a:documentation>Erzeugt eine „Wenn-Dann-Abfrage“. Das heißt, für jedes Kindelement Case wird überprüft, ob die Bedingung erfüllt ist. Wenn ja, dann wird der Inhalt des Kindelements Case ausgeführt und die Verarbeitung hinter der Fallunterscheidung fortgesetzt. Wenn keine Bedingung erfüllt wurde und ein Element Otherwise gefunden wurde, wird der         Inhalt des Elements Otherwise ausgeführt. Durch das frühzeitige Abbrechen werden nachfolgende Fälle nicht weiter untersucht (siehe Beispiel).</a:documentation>
            <interleave>
                <group>
                    <oneOrMore>
                        <ref name="e_Case"></ref>
                    </oneOrMore>
                    <optional>
                        <ref name="e_Otherwise"></ref>
                    </optional>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_StyleSheet">
        <element name="StyleSheet">
            <a:documentation>Lädt eine CSS-Datei oder definiert CSS-Eigenschaften</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="href">
                            <a:documentation>Der Dateiname der CSS Datei (inklusive Dateiendung).</a:documentation>
                        </attribute>
                    </optional>
                    <text></text>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Table">
        <element name="Table">
            <a:documentation>Erzeugt eine Tabelle, die in etwa dem HTML Tabellenmodell entspricht.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="width">
                            <a:documentation>Der Bereich, den die Tabelle (maximal) im Raster belegt. Angabe in Rasterzellen oder absoluten Längenangaben. Voreinstellung ist der verfügbare Platz.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS Klasse für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS Stil für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="stretch">
                            <a:documentation>Wenn auf &#34;max&#34; gesetzt, wird die Tabelle auf die volle Breite gedehnt (entspricht CSS width: 100%).</a:documentation>
                            <choice>
                                <value>max</value>
                                <a:documentation>Tabelle auf die maximale Breite dehnen.</a:documentation>
                            </choice>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Columns"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Loop"></ref>
                            </optional>
                            <optional>
                                <ref name="e_TableHead"></ref>
                            </optional>
                            <optional>
                                <ref name="e_TableRule"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Tr"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_TableHead">
        <element name="TableHead">
            <a:documentation>Gibt den Tabellenkopf an.</a:documentation>
            <interleave>
                <group>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Switch"></ref>
                            </optional>
                            <optional>
                                <ref name="e_TableRule"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Tr"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_TableRule">
        <element name="TableRule">
            <a:documentation>Zeichnet eine horizontale Linie über die gesamte Tabellenbreite. Standarddicke ist 0,4 Punkt.</a:documentation>
            <optional>
                <attribute name="rulewidth">
                    <a:documentation>Dicke der Linie. Voreinstellung ist 0,4 Punkt.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="color">
                    <a:documentation>Farbe der Linie. Mit »transparent« wird nur Platz reserviert. Voreinstellung ist schwarz.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="class">
                    <a:documentation>CSS-Klasse für dieses Element.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="id">
                    <a:documentation>CSS-ID für dieses Element.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="style">
                    <a:documentation>CSS-Style für dieses Element. Überschreibt die Attribute rulewidth und color.</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Td">
        <element name="Td">
            <a:documentation>Erstellt eine Tabellenzelle, wie in HTML</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>Die CSS-Klasse für die Formtierung.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id für diese Tabellenzelle.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS Stil für diese Tabellenzelle.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="colspan">
                            <a:documentation>Die Anzahl der Spalten, die die Zelle überdecken soll. Voreinstellung ist 1.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="rowspan">
                            <a:documentation>Die Anzahl der Zeilen, die die Zelle überdecken soll. Voreinstellung ist 1.</a:documentation>
                        </attribute>
                    </optional>
                    <zeroOrMore>
                        <choice>
                            <ref name="e_Bookmark"></ref>
                            <ref name="e_Box"></ref>
                            <ref name="e_ForAll"></ref>
                            <ref name="e_SlateContents"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_Image"></ref>
                            <ref name="e_Loop"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_Paragraph"></ref>
                            <ref name="e_Switch"></ref>
                            <ref name="e_Table"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                        </choice>
                    </zeroOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_TextBlock">
        <element name="TextBlock">
            <a:documentation>Erzeugt einen rechteckigen Bereich mit Text.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="parsep">
                            <a:documentation>Der vertikale Abstand zwischen zwei Absätzen.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="width">
                            <a:documentation>Anzahl der Spalten, die der Text einnehmen soll. Wenn das Attribut nicht angegeben wird, so bestimmt das umliegende Element die Breite.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <choice>
                            <ref name="e_Action"></ref>
                            <ref name="e_ForAll"></ref>
                            <ref name="e_Bookmark"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_Paragraph"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                        </choice>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Tr">
        <element name="Tr">
            <a:documentation>Erstellt eine Tabellenzeile</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS Klasse für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS Stil für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <optional>
                            <ref name="e_Message"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Td"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Value"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Switch"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ForAll"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Loop"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Trace">
        <element name="Trace">
            <a:documentation>Setze Debugging-Schalter</a:documentation>
            <optional>
                <attribute name="dests">
                    <a:documentation>Zeige PDF Ziele mit einem schwarzen Kreis.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Zeige Ziele.</a:documentation>
                        <value>no</value>
                        <a:documentation>Ziele nicht zeigen (Voreinstellung).</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="grid">
                    <a:documentation>Wenn &#39;yes&#39;, dann zeichnet der Publisher das zugrunde liegende Raster auf die Seiten.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Zeige das Raster.</a:documentation>
                        <value>no</value>
                        <a:documentation>Das Raster wird nicht angezeigt (Voreinstellung).</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="gridallocation">
                    <a:documentation>Wenn &#39;yes&#39;, dann markiert der Publisher die belegten Rasterzellen mit einer Hintergrundfarbe.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Zeige Rasterbelegung.</a:documentation>
                        <value>no</value>
                        <a:documentation>Rasterbelegung nicht zeigen (Voreinstellung).</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="hyperlinks">
                    <a:documentation>Wenn &#39;yes&#39;, dann zeichnet XTS einen Rahmen um die Hyperlinks.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Zeige die Hyperlinks.</a:documentation>
                        <value>no</value>
                        <a:documentation>Die Hyperlinks werden nicht angezeigt (Voreinstellung).</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="hyphenation">
                    <a:documentation>Bei &#39;yes&#39; markiert der speedata Publisher die möglichen Trennstellen für die Silbentrennung.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Zeige Silbentrennungsmöglichkeiten.</a:documentation>
                        <value>no</value>
                        <a:documentation>Keine Silbentrennungsmöglichkeiten zeigen (Voreinstellung).</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="objects">
                    <a:documentation>Zeichnet Kästchen um Objekte.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Zeige Objekte.</a:documentation>
                        <value>no</value>
                        <a:documentation>Keine Kästchen zeigen.</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Ul">
        <element name="Ul">
            <a:documentation>Erzeugt eine Stichpunktliste mit Aufzählungspunkten</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS Klasse für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS Stil für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Li"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_U">
        <element name="U">
            <a:documentation>Unterstreiche Text.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS Klasse für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS Stil für dieses Element.</a:documentation>
                        </attribute>
                    </optional>
                    <zeroOrMore>
                        <choice>
                            <ref name="e_A"></ref>
                            <ref name="e_Action"></ref>
                            <ref name="e_B"></ref>
                            <ref name="e_Br"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_I"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_U"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                            <ref name="e_CopyOf"></ref>
                            <ref name="e_Span"></ref>
                        </choice>
                    </zeroOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Until">
        <element name="Until">
            <a:documentation>Erzeugt eine Schleife. Die Kindelemente werden so oft ausgeführt, bis die Bedingung im Attribut »wahr« ergibt. Der Rückgabewert von Until ist der aneinandergekettete Rückgabewert aller Kindelemente.</a:documentation>
            <interleave>
                <group>
                    <attribute name="test">
                        <a:documentation>Nach jedem Schleifendurchlauf wird die Bedingung überprüft. Wenn sie »wahr« ergibt, wird die Schleife verlassen.</a:documentation>
                    </attribute>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Column"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ClearPage"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                            <optional>
                                <ref name="e_HTML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_LoadXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Loop"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Li"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Message"></ref>
                            </optional>
                            <optional>
                                <ref name="e_NextFrame"></ref>
                            </optional>
                            <optional>
                                <ref name="e_NextRow"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Paragraph"></ref>
                            </optional>
                            <optional>
                                <ref name="e_PlaceObject"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ProcessNode"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SaveXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SetVariable"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Switch"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Td"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Tr"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Until"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                            <optional>
                                <ref name="e_While"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_HTML">
        <element name="HTML">
            <a:documentation>Fügt HTML-Inhalt ein, entweder inline oder per XPath-Ausdruck ermittelt.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="select">
                            <a:documentation>XPath-Ausdruck, der ein XML/HTML-Fragment liefert.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="expand-text">
                            <a:documentation>Bei &#34;yes&#34; werden Ausdrücke in geschweiften Klammern {expr} im HTML-Inhalt als XPath-Ausdrücke ausgewertet (ähnlich wie XSLT 3.0 Text Value Templates). Für literale geschweifte Klammern {{ und }} verwenden. Standard ist &#34;no&#34;.</a:documentation>
                            <choice>
                                <value>yes</value>
                                <value>no</value>
                            </choice>
                        </attribute>
                    </optional>
                    <ref name="html"></ref>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Value">
        <element name="Value">
            <a:documentation>Beinhaltet einen Textinhalt, der an das umgebende Element übergeben wird (immer als reiner Text).</a:documentation>
            <optional>
                <attribute name="select">
                    <a:documentation>Wert, der zum umgebenden Element übergeben wird.</a:documentation>
                </attribute>
            </optional>
            <ref name="anycontent"></ref>
        </element>
    </define>
    <define name="e_While">
        <element name="While">
            <a:documentation>Erzeugt eine Schleife, die wiederholt durchlaufen wird. Die Kindelemente werden so oft ausgeführt, solange die Bedingung im Attribut »wahr« ergibt.</a:documentation>
            <interleave>
                <group>
                    <attribute name="test">
                        <a:documentation>Für jedes Mal, das die Schleife durchlaufen werden soll, muss die Bedingung im Attribut erfüllt sein. Die Bedingung wird am Anfang der Schleife überprüft. Eine Schleife, bei der die Bedingung am Ende der Schleife geprüft wird, ist Until.</a:documentation>
                    </attribute>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Column"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ClearPage"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                            <optional>
                                <ref name="e_HTML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_LoadXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Loop"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Li"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Message"></ref>
                            </optional>
                            <optional>
                                <ref name="e_NextFrame"></ref>
                            </optional>
                            <optional>
                                <ref name="e_NextRow"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Paragraph"></ref>
                            </optional>
                            <optional>
                                <ref name="e_PlaceObject"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ProcessNode"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SaveXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SetVariable"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Switch"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Td"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Tr"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Until"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                            <optional>
                                <ref name="e_While"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
	<!-- allow HTML in <Value> ... </Value> -->
    <define name="htmlclassidstyle">
        <optional><attribute name="class"/></optional>
        <optional><attribute name="id"/></optional>
        <optional><attribute name="style"/></optional>
    </define>
	<define name="html">
		<zeroOrMore>
		    <choice>
			    <element name="a">
				    <attribute name="href"/>
				    <ref name="html"/>
			    </element>
			    <element name="b"><ref name="html" /></element>
			    <element name="barcode">
				    <attribute name="type"/>
				    <attribute name="value"/>
				    <optional><attribute name="width"/></optional>
				    <optional><attribute name="height"/></optional>
				    <optional><attribute name="eclevel"/></optional>
			    </element>
			    <element name="br"><empty /></element>
			    <element name="code"><ref name="html" /></element>
			    <element name="div">
				    <ref name="htmlclassidstyle"/>
				    <ref name="html" />
			    </element>
			    <element name="em"><ref name="html" /></element>
			    <element name="h1"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="h2"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="h3"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="h4"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="h5"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="h6"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="i"><ref name="html" /></element>
			    <element name="img">
				    <attribute name="src"/>
				    <optional><attribute name="width"/></optional>
				    <optional><attribute name="height"/></optional>
				    <optional><attribute name="alt"/></optional>
				    <ref name="htmlclassidstyle"/>
			    </element>
			    <element name="kbd"><ref name="html" /></element>
			    <element name="li"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="ol"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="p">
					<ref name="htmlclassidstyle"/>
				<ref name="html" /></element>
			    <element name="pre"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="span"><ref name="html" /><oneOrMore><attribute><anyName/></attribute></oneOrMore></element>
			    <element name="strong"><ref name="html" /></element>
                <element name="table"><ref name="htmltable" /></element>
			    <element name="u"><ref name="html" /></element>
			    <element name="ul"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element>
				    <nsName ns="http://www.w3.org/1999/xhtml"/>
				    <zeroOrMore>
					    <attribute><anyName/></attribute>
				    </zeroOrMore>
				    <ref name="xhtmlcontent"/>
			    </element>
			    <text></text>
		    </choice>
		</zeroOrMore>
	</define>
	<define name="xhtmlcontent">
		<zeroOrMore>
		    <choice>
			    <element>
				    <nsName ns="http://www.w3.org/1999/xhtml"/>
				    <zeroOrMore>
					    <attribute><anyName/></attribute>
				    </zeroOrMore>
				    <ref name="xhtmlcontent"/>
			    </element>
			    <element>
				    <nsName ns="urn:speedata.de/2021/xts/en"/>
				    <zeroOrMore>
					    <attribute><anyName/></attribute>
				    </zeroOrMore>
				    <ref name="xhtmlcontent"/>
			    </element>
			    <text></text>
		    </choice>
		</zeroOrMore>
	</define>
    <define name="htmltable">
        <ref name="htmlclassidstyle"/>
        <zeroOrMore>
            <ref name="colgroup"/>
        </zeroOrMore>
        <optional>
            <element name="thead">
                <ref name="htmlclassidstyle" />
                <oneOrMore>
                    <ref name="tr"/>
                </oneOrMore>
            </element>
        </optional>
        <choice>
            <optional>
                <element name="tbody">
                    <ref name="htmlclassidstyle" />
                    <oneOrMore>
                        <ref name="tr"/>
                    </oneOrMore>
                </element>
            </optional>
            <oneOrMore>
                <ref name="tr"/>
            </oneOrMore>
        </choice>
    </define>
    <define name="colgroup">
        <element name="colgroup">
            <oneOrMore>
                <element name="col">
                    <attribute name="width"/>
                    <empty />
                </element>
            </oneOrMore>
        </element>
    </define>
    <define name="tr">
        <element name="tr">
            <ref name="htmlclassidstyle"/>
            <oneOrMore>
                <choice>
                    <element name="td">
                        <ref name="htmlclassidstyle"></ref>
                        <ref name="html"/>
                    </element>
                    <element name="th">
                        <ref name="htmlclassidstyle"></ref>
                        <ref name="html"/>
                    </element>
                </choice>
            </oneOrMore>
        </element>
    </define>
	<!-- This pattern allows any element from any namespace -->
	<define name="anything">
      <zeroOrMore>
         <choice>
            <element>
               <anyName/>
               <ref name="anything"/>
            </element>
            <attribute>
               <anyName/>
            </attribute>
            <text/>
         </choice>
      </zeroOrMore>
   </define>
   <!-- Like anything but without top-level attributes (for use alongside explicit attributes) -->
   <define name="anycontent">
      <zeroOrMore>
         <choice>
            <element>
               <anyName/>
               <ref name="anything"/>
            </element>
            <text/>
         </choice>
      </zeroOrMore>
   </define>

   <define name="foreign-elements">
      <zeroOrMore>
         <element>
            <anyName>
               <except>
                  <nsName ns=""/>
                  <nsName ns="urn:speedata.de/2021/xts/en"/>
                  <nsName ns="urn:speedata.de/2021/xtsfunctions/en"/>
                  <nsName ns="http://www.w3.org/1999/xhtml"/>
               </except>
            </anyName>
            <ref name="anything"/>
         </element>
      </zeroOrMore>
   </define>
   <define name="foreign-attributes">
      <zeroOrMore>
         <attribute>
            <anyName>
               <except>
                  <nsName ns=""/>
                  <nsName ns="urn:speedata.de/2021/xts/en"/>
                  <nsName ns="urn:speedata.de/2021/xtsfunctions/en"/>
                  <nsName ns="http://www.w3.org/1999/xhtml"/>
               </except>
            </anyName>
         </attribute>
      </zeroOrMore>
   </define>
   <define name="foreign-nodes">
      <zeroOrMore>
         <choice>
            <ref name="foreign-attributes"/>
            <ref name="foreign-elements"/>
         </choice>
      </zeroOrMore>
   </define>

</grammar>
