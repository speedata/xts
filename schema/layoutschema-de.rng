    <define name="e_Circle">
        <element name="Circle">
            <a:documentation>Erzeugt einen Kreis oder eine Ellipse.</a:documentation>
            <optional>
                <attribute name="background-color">
                    <a:documentation>Farbe des Kreises.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="class">
                    <a:documentation>CSS Klasse für diesen Kreis.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="border-color">
                    <a:documentation>Farbe der Kreislinie.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="id">
                    <a:documentation>CSS id für diesen Kreis.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="style">
                    <a:documentation>CSS Stil für dieses Element.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="origin-x">
                    <a:documentation>Bestimmt den horizontalen Bereich, der an den angegebenen Koordinaten bei PlaceObject liegt. Die Werte liegen zwischen 0 (linke Kante) und 100 (rechte Kante), wobei die Voreinstellung 50 ist.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="origin-y">
                    <a:documentation>Bestimmt den vertikalen Bereich, der an den angegebenen Koordinaten bei PlaceObject liegt. Die Werte liegen zwischen 0 (obere Kante) und 100 (untere Kante), wobei die Voreinstellung 50 ist.</a:documentation>
                </attribute>
            </optional>
            <attribute name="radius-x">
                <a:documentation>Radius des Kreises in Rasterzellen (horizontal) oder als absolute Maßangabe. In Verbindung mit radius-y lässt sich eine Ellipse erzeugen.</a:documentation>
            </attribute>
            <optional>
                <attribute name="radius-y">
                    <a:documentation>Radius der Ellipse in Rasterzellen (vertikal) oder als absolute Maßangabe.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="border-width">
                    <a:documentation>Die Dicke des Striches um den Kreis.</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_ClearPage">
        <element name="ClearPage">
            <a:documentation>Beendet die Ausgabe auf der aktuellen Seite.</a:documentation>
            <empty></empty>
        </element>
    </define>
    <define name="e_Column">
        <element name="Column">
            <a:documentation>Gibt die Eigenschaften einer Spalte in einer Tabelle an.</a:documentation>
            <optional>
                <attribute name="width">
                    <a:documentation>Breite der Spalte. Kann entweder in Rasterzellen (Zahl), absoluten Maßangaben (z.B. 1cm) oder in *-Angaben (z.B. 4*) angegeben werden.</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
