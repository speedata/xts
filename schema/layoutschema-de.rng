    <define name="e_Action">
        <element name="Action">
            <a:documentation>Assoziiert eine Aktion mit einem Text. Sobald der Text auf einer Seite platziert wird, wird die dazugehörige Aktion ausgeführt. Die Aktion kann man sich als unsichtbares Zeichen vorstellen. Wenn der Publisher das unsichtbare Zeichen ausgibt, werden die Anweisungen in der Aktion ausgeführt.</a:documentation>
            <interleave>
                <group>
                    <oneOrMore>
                        <ref name="e_Mark"></ref>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
