    <define name="e_DefineColor">
        <element name="DefineColor">
            <a:documentation>Definiert Farben, die später im Layout benutzt werden können</a:documentation>
            <optional>
                <attribute name="colorname">
                    <a:documentation>Der Name der Sonderfarbe wenn das Modell auf »spotcolor« eingestellt ist. Der muss den offiziellen Namen tragen, wie z.B. »PANTONE 116 C«.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="model">
                    <a:documentation>Das Farbmodell, das benutzt werden soll. Derzeit werden »rgb«, »cmyk«, »gray« und »spotcolor« unterstützt.</a:documentation>
                    <choice>
                        <value>cmyk</value>
                        <a:documentation>CMYK (Türkis, Magenta, Gelb und Schwarz), Werte zwischen 0 und 100 (100 = volle Intensität)</a:documentation>
                        <value>rgb</value>
                        <a:documentation>RGB (Rot, Grün, Blau), Werte zwischen 0 und 100, 100 bedeutet volle Intensität</a:documentation>
                        <value>RGB</value>
                        <a:documentation>RGB (Rot, Grün, Blau), Werte zwischen 0 und 255, 255 bedeutet volle Intensität</a:documentation>
                        <value>gray</value>
                        <a:documentation>Graustufen (0=Schwarz,100=Weiß)</a:documentation>
                        <value>spotcolor</value>
                        <a:documentation>Eine PANTONE oder HKS Farbe.</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <attribute name="name">
                <a:documentation>Name der Farbe, die definiert wird.</a:documentation>
            </attribute>
            <optional>
                <attribute name="value">
                    <a:documentation>Der Hexwert der Farbe, wie beispielsweise #FA5 oder #FFAA55 oder rgb(255,170,85) oder rgba(255,170,85,1).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="r">
                    <a:documentation>Rot Anteil bei rgb (0-100) oder RGB (0-255).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="g">
                    <a:documentation>Grün Anteil bei rgb (0-100) oder RGB (0-255) bzw. Grauanteil beim Farbmodell gray (0-100).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="b">
                    <a:documentation>Blau Anteil bei rgb (0-100) oder RGB (0-255).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="c">
                    <a:documentation>Cyan Anteil bei cmyk (0-100).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="m">
                    <a:documentation>Magenta Anteil bei cmyk (0-100)</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="y">
                    <a:documentation>Gelb Anteil bei cmyk (0-100).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="k">
                    <a:documentation>Schwarz (key) Anteil bei cmyk (0-100).</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_DefineMasterPage">
        <element name="DefineMasterPage">
            <a:documentation>Definiert eine Seitenvorlage. Anhand der Kriterien, die im Attribut test angegeben werden, wählt das System eine Seitenvorlage aus.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="margin">
                            <a:documentation>Setzt den Rand der Seite (Voreinstellung 1cm). Ein bis vier Werte können übergeben werden, wie bei CSS.</a:documentation>
                        </attribute>
                    </optional>
                    <attribute name="name">
                        <a:documentation>Name der Seitenvorlage. Der Name ist zu Informationszwecken und zur Auswahl bei ClearPage.</a:documentation>
                    </attribute>
                    <attribute name="test">
                        <a:documentation>Wenn der XPath-Ausdruck »wahr« ergibt, dann wird diese Seite als Vorlage genommen.</a:documentation>
                    </attribute>
                    <interleave>
                        <optional>
                            <oneOrMore>
                                <ref name="e_PositioningArea"></ref>
                            </oneOrMore>
                        </optional>
                        <optional>
                            <ref name="e_AtPageCreation"></ref>
                        </optional>
                        <optional>
                            <ref name="e_AtPageShipout"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ForAll"></ref>
                        </optional>
                    </interleave>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
