    <define name="e_Circle">
        <element name="Circle">
            <a:documentation>Create a circle or ellipse.</a:documentation>
            <optional>
                <attribute name="background-color">
                    <a:documentation>Color of the circle.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="class">
                    <a:documentation>CSS class for the circle.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="border-color">
                    <a:documentation>Color of the circle line.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="id">
                    <a:documentation>CSS id for this circle.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="style">
                    <a:documentation>CSS style for this element.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="origin-x">
                    <a:documentation>Determines the horizontal area where the coordinates from PlaceObject are located. Value is from 0 (left edge) to 100 (right edge), with a default of 50 (horizontally centered).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="origin-y">
                    <a:documentation>Determines the vertical area where the coordinates from PlaceObject are located. Value is from 0 (top edge) to 100 (bottom edge), with a default of 50 (verically centered).</a:documentation>
                </attribute>
            </optional>
            <attribute name="radius-x">
                <a:documentation>Radius of the circle in grid cells (horizontal) or as an absolute length. Use with radius-y to create an ellipse.</a:documentation>
            </attribute>
            <optional>
                <attribute name="radius-y">
                    <a:documentation>Radius of the ellipse in grid cells (vertical) or as an absolute length.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="border-width">
                    <a:documentation>The thickness of the border that is drawn around the object.</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_ClearPage">
        <element name="ClearPage">
            <a:documentation>Finishes the current page.</a:documentation>
            <empty></empty>
        </element>
    </define>
    <define name="e_Column">
        <element name="Column">
            <a:documentation>Set the properties of a column in the table.</a:documentation>
            <optional>
                <attribute name="width">
                    <a:documentation>Width of the column. Argument can be a number (in grid cells) a length (e.g. 2cm) or a *-number (e.g. 4*).</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Columns">
        <element name="Columns">
            <a:documentation>Set the widths and other properties of the columns in a table.</a:documentation>
            <interleave>
                <group>
                    <oneOrMore>
                        <choice>
                            <ref name="e_Column"></ref>
