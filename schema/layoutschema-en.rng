                        <optional>
                            <ref name="e_Message"></ref>
                        </optional>
                        <optional>
                            <ref name="e_NextFrame"></ref>
                        </optional>
                        <optional>
                            <ref name="e_NextRow"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PlaceObject"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ProcessNode"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SaveXML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetVariable"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Switch"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Value"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Slate">
        <element name="Slate">
            <a:documentation>Create a virtual page (a slate) that behaves like a real page but is not placed into the PDF. Think of it as a magic slate — you draw on it, inspect the result, and then place it on the page.</a:documentation>
            <interleave>
                <group>
                    <attribute name="name">
                        <a:documentation>Name of the slate that is created.</a:documentation>
                    </attribute>
                    <ref name="e_Contents"></ref>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_SlateContents">
        <element name="SlateContents">
            <a:documentation>Insert the contents of a previously created slate.</a:documentation>
            <attribute name="name">
                <a:documentation>Name of the slate whose contents should be inserted.</a:documentation>
            </attribute>
            <empty></empty>
        </element>
    </define>
    <define name="e_I">
        <element name="I">
            <a:documentation>Switch to italic text.</a:documentation>
            <interleave>
                <group>
                    <zeroOrMore>
                        <choice>
                            <ref name="e_A"></ref>
                            <ref name="e_Action"></ref>
                            <ref name="e_B"></ref>
                            <ref name="e_Br"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_I"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_U"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                            <ref name="e_CopyOf"></ref>
                            <ref name="e_Span"></ref>
                        </choice>
                    </zeroOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Image">
        <element name="Image">
            <a:documentation>Includes an external Graphic. Allowed graphic formats are PDF (.pdf), PNG (.png) and JPEG (.jpg). See below for a limitation on the number of included PDF files.</a:documentation>
            <optional>
                <attribute name="href">
                    <a:documentation>Filename of the image. Can be a file in the search path, an absolute file name, a file-URI for absolute paths (e.g. file:///path/to/image.pdf) or a location on the web (http, https). Use placeholder://WxH (e.g. placeholder://200x150) to generate a placeholder image with the given dimensions in PDF points.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="height">
                    <a:documentation>Image height. One of &#39;auto&#39; (default, take image width), length (such as &#39;3cm&#39;) or number (in grid cells).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="page">
                    <a:documentation>The page number from the PDF. Default is 1 (include the first page).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="maxwidth">
                    <a:documentation>The maximum width of the image. Only used when clip=&#34;no&#34;. Value is a number (grid cells), a length or the value “100%” for full width image.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="maxheight">
                    <a:documentation>The maximum height of the image. Only used when clip=&#34;no&#34;. Value is a number (grid cells) or a length.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="minwidth">
                    <a:documentation>The minimum width of the image. Only used when clip=&#34;no&#34;. Value is a number (grid cells), a length or the value “100%” for full width image.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="minheight">
                    <a:documentation>The minimum height of the image. Only used when clip=&#34;no&#34;. Value is a number (grid cells) or a length.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="stretch">
                    <a:documentation>Stretch image until one of maximum width and maximum height is reached. Useful if images should be as large as possible but should not use more than the given space.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <value>no</value>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="visiblebox">
                    <a:documentation>The PDF box that represents the visible area of the included image. Default is “cropbox”.</a:documentation>
                    <choice>
                        <value>artbox</value>
                        <a:documentation>Use the artbox as the visible area. The artbox is usually not contained in a PDF.</a:documentation>
                        <value>bleedbox</value>
                        <a:documentation>Use the bleedbox of the included PDF.</a:documentation>
                        <value>cropbox</value>
                        <a:documentation>Use the cropbox of the included PDF (default).</a:documentation>
                        <value>mediabox</value>
                        <a:documentation>Use the mediabox of the included PDF. This is the largest box.</a:documentation>
                        <value>trimbox</value>
                        <a:documentation>Use the trimbox of the includes PDF. The trimbox is the final paper size. For example, the trim box of an A4 PDF is 210mm x 297mm.</a:documentation>
                        <data type="string">
                            <param name="pattern">\{.+\}</param>
                        </data>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="width">
                    <a:documentation>Image width. One of &#39;auto&#39; (default, take image width), &#39;100%&#39; (whole area width), length (such as &#39;3cm&#39;) or number (in grid cells).</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_LoadXML">
        <element name="LoadXML">
            <a:documentation>Load an XML file previously written by SaveXML (attribute name) or a well formed XML file (attribute href). The regular data processing is interrupted and the contents of the data file is taken as a data source. If the file does not exist, the call to LoadXML is ignored.</a:documentation>
            <optional>
                <attribute name="name">
                    <a:documentation>Name of the data file. Example: toc</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="href">
                    <a:documentation>Filename of the XML file to load. Example: myfile.xml.</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Li">
        <element name="Li">
            <a:documentation>List item in an ordered or unordered list.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS class for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS style for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <zeroOrMore>
                        <choice>
                            <ref name="e_A"></ref>
                            <ref name="e_Action"></ref>
                            <ref name="e_B"></ref>
                            <ref name="e_Br"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_I"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_U"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                            <ref name="e_CopyOf"></ref>
                            <ref name="e_Span"></ref>
                        </choice>
                    </zeroOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Loop">
        <element name="Loop">
            <a:documentation>Repeat the contents of this element several times.</a:documentation>
            <interleave>
                <group>
                    <attribute name="select">
                        <a:documentation>The number of loops. Must be a number or castable as a number.</a:documentation>
                    </attribute>
                    <optional>
                        <attribute name="variable">
                            <a:documentation>If given, store the current loop value in this variable. If omitted, the loop value is stored in the variable _loopcounter.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Column"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ClearPage"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                            <optional>
                                <ref name="e_HTML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_LoadXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Loop"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Li"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Message"></ref>
                            </optional>
                            <optional>
                                <ref name="e_NextFrame"></ref>
                            </optional>
                            <optional>
                                <ref name="e_NextRow"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Paragraph"></ref>
                            </optional>
                            <optional>
                                <ref name="e_PlaceObject"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ProcessNode"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SaveXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SetVariable"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Switch"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Td"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Tr"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Until"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                            <optional>
                                <ref name="e_While"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Message">
        <element name="Message">
            <a:documentation>Writes a message onto the console and to the protocol file.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="select">
                            <a:documentation>Contents of the message. You can alternatively specify the message by the child elements Value.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="type">
                            <a:documentation>The type of the message.</a:documentation>
                            <choice>
                                <value>error</value>
                                <a:documentation>Report an error.</a:documentation>
                                <value>warning</value>
                                <a:documentation>Report a warning.</a:documentation>
                                <value>debug</value>
                                <a:documentation>Report a debug message.</a:documentation>
                                <value>notice</value>
                                <a:documentation>Report an information (default).</a:documentation>
                            </choice>
                        </attribute>
                    </optional>
                    <interleave>
                        <optional>
                            <oneOrMore>
                                <ref name="e_Value"></ref>
                            </oneOrMore>
                        </optional>
                        <optional>
                            <oneOrMore>
                                <ref name="e_Element"></ref>
                            </oneOrMore>
                        </optional>
                    </interleave>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Layout">
        <element name="Layout">
            <a:documentation>This command is the root element in the Layout instructions.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="version">
                            <a:documentation>Minimum publisher version required. If major or minor version differ, give a warning. Format: 1.6.12 (revision number can be left out).</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <optional>
                            <ref name="e_DefineColor"></ref>
                        </optional>
                        <optional>
                            <ref name="e_DefineMasterPage"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Function"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Message"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Options"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PDFOptions"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PageFormat"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Record"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Section"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetGrid"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetVariable"></ref>
                        </optional>
                        <optional>
                            <ref name="e_StyleSheet"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Trace"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Layout"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Mark">
        <element name="Mark">
            <a:documentation>Sets an invisible mark into the output. This is helpful when you want to know on which page the mark is placed on.</a:documentation>
            <optional>
                <attribute name="append">
                    <a:documentation>When yes, append the current page to the previous values of the mark. Useful to get page ranges in an index. (Default is no.)</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Append the page number to the previous value of the mark.</a:documentation>
                        <value>no</value>
                        <a:documentation>Replace the previous value.</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <attribute name="select">
                <a:documentation>The name of the mark to be set.</a:documentation>
            </attribute>
            <optional>
                <attribute name="shiftup">
                    <a:documentation>Raise the position of the hyperlink anchor by this amount.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="pdftarget">
                    <a:documentation>Set a pdf target that can be referenced by A</a:documentation>
                    <choice>
                        <value>yes</value>
                        <value>no</value>
                    </choice>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_NextFrame">
        <element name="NextFrame">
            <a:documentation>Switch to the next free frame of a positioning area.</a:documentation>
            <attribute name="area">
                <a:documentation>Name of the positioning area.</a:documentation>
            </attribute>
            <empty></empty>
        </element>
    </define>
    <define name="e_NextRow">
        <element name="NextRow">
            <a:documentation>The virtual cursor is set on the next free row.</a:documentation>
            <optional>
                <attribute name="area">
                    <a:documentation>Name of the area of the virtual cursor.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="row">
                    <a:documentation>The absolute number of the row for the cursor. If no row is given, the system tries to find a completely free row (perhaps on an empty page).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="rows">
                    <a:documentation>The number of rows to clear. Defaults to 1.</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Ol">
        <element name="Ol">
            <a:documentation>Create an ordered list, just like in HTML</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS class for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS style for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Li"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Options">
        <element name="Options">
            <a:documentation>Set publisher specific options.</a:documentation>
            <optional>
                <attribute name="bleed">
                    <a:documentation>The amount of bleed. Defaults to 0mm.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="cutmarks">
                    <a:documentation>Cut marks / crop marks will be placed in the PDF. The distance of the marks from the imaginary center is determined by the attribute trim, but is at least 5mm. The length of the cut marks is 1cm. The default of this attribute is no, that means no cut marks will be displayed.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Show crop marks.</a:documentation>
                        <value>no</value>
                        <a:documentation>Don&#39;t show crop marks (default).</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="features">
                    <a:documentation>A comma separated list of OpenType features such as +kern,-liga. Used as a default for all paragraphs.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="mainlanguage">
                    <a:documentation>The default language for text (hyphenation and rendering). You can also set the default language on the command line and locally set it at Paragraph and TextBlock.</a:documentation>
                    <choice>
                        <data type="string">
                            <param name="pattern">\{.+\}</param>
                        </data>
                        <data type="string">
                            <param name="pattern">--|bg|ca|cs|cy|da|de|el|en|en_GB|en_US|eo|es|et|eu|fi|fr|ga|gl|grc|gu|hi|hr|hu|hy|id|is|it|kn|ku|lt|lv|ml|nb|nl|nn|pl|pt|ro|ru|sc|sk|sl|sr|sv|tr|uk|zh</param>
                        </data>
                        <value>Ancient Greek</value>
                        <a:documentation>Ancient Greek</a:documentation>
                        <value>Armenian</value>
                        <a:documentation>Armenian</a:documentation>
                        <value>Bahasa Indonesia</value>
                        <a:documentation>Bahasa Indonesia</a:documentation>
                        <value>Basque</value>
                        <a:documentation>Basque</a:documentation>
                        <value>Bulgarian</value>
                        <a:documentation>Bulgarian (latin alphabet)</a:documentation>
                        <value>Catalan</value>
                        <a:documentation>Catalan</a:documentation>
                        <value>Chinese</value>
                        <a:documentation>Chinese language setting.</a:documentation>
                        <value>Croatian</value>
                        <a:documentation>Croatian</a:documentation>
                        <value>Czech</value>
                        <a:documentation>Czech</a:documentation>
                        <value>Danish</value>
                        <a:documentation>Danish</a:documentation>
                        <value>Dutch</value>
                        <a:documentation>Dutch</a:documentation>
                        <value>English (Great Britain)</value>
                        <a:documentation>British</a:documentation>
                        <value>English (USA)</value>
                        <a:documentation>American English</a:documentation>
                        <value>Esperanto</value>
                        <a:documentation>Esperanto</a:documentation>
                        <value>Estonian</value>
                        <a:documentation>Estonian</a:documentation>
                        <value>Finnish</value>
                        <a:documentation>Finnish</a:documentation>
                        <value>French</value>
                        <a:documentation>French</a:documentation>
                        <value>Galician</value>
                        <a:documentation>Galician</a:documentation>
                        <value>German</value>
                        <a:documentation>German</a:documentation>
                        <value>Greek</value>
                        <a:documentation>Monotonic Greek</a:documentation>
                        <value>Gujarati</value>
                        <a:documentation>Gujarati</a:documentation>
                        <value>Hungarian</value>
                        <a:documentation>Hungarian</a:documentation>
                        <value>Hindi</value>
                        <a:documentation>Hindi</a:documentation>
                        <value>Icelandic</value>
                        <a:documentation>Icelandic</a:documentation>
                        <value>Irish</value>
                        <a:documentation>Irish</a:documentation>
                        <value>Italian</value>
                        <a:documentation>Italian</a:documentation>
                        <value>Kannada</value>
                        <a:documentation>Kannada</a:documentation>
                        <value>Kurmanji</value>
                        <a:documentation>Kurmanji</a:documentation>
                        <value>Latvian</value>
                        <a:documentation>Latvian</a:documentation>
                        <value>Lithuanian</value>
                        <a:documentation>Lithuanian</a:documentation>
                        <value>Malayalam</value>
                        <a:documentation>Malayalam</a:documentation>
                        <value>Norwegian Bokmål</value>
                        <a:documentation>Norwegian Bokmål</a:documentation>
                        <value>Norwegian Nynorsk</value>
                        <a:documentation>Norwegian Nynorsk</a:documentation>
                        <value>Other</value>
                        <a:documentation>Don&#39;t any of these languages. Useful if a text does not render correctly.</a:documentation>
                        <value>Polish</value>
                        <a:documentation>Polish</a:documentation>
                        <value>Portuguese</value>
                        <a:documentation>Portuguese</a:documentation>
                        <value>Romanian</value>
                        <a:documentation>Romanian</a:documentation>
                        <value>Russian</value>
                        <a:documentation>Russian</a:documentation>
                        <value>Serbian</value>
                        <a:documentation>Serbian</a:documentation>
                        <value>Serbian (cyrillic)</value>
                        <a:documentation>Serbian (cyrillic script).</a:documentation>
                        <value>Slovak</value>
                        <a:documentation>Slovak</a:documentation>
                        <value>Slovenian</value>
                        <a:documentation>Slovenian</a:documentation>
                        <value>Spanish</value>
                        <a:documentation>Spanish</a:documentation>
                        <value>Swedish</value>
                        <a:documentation>Swedish</a:documentation>
                        <value>Turkish</value>
                        <a:documentation>Turkish</a:documentation>
                        <value>Ukrainian</value>
                        <a:documentation>Ukrainian</a:documentation>
                        <value>Welsh</value>
                        <a:documentation>Welsh</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Otherwise">
        <element name="Otherwise">
            <a:documentation>Default branch of a Switch command.</a:documentation>
            <interleave>
                <group>
                    <oneOrMore>
                        <optional>
                            <ref name="e_Column"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ClearPage"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ForAll"></ref>
                        </optional>
                        <optional>
                            <ref name="e_HTML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_LoadXML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Loop"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Li"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Message"></ref>
                        </optional>
                        <optional>
                            <ref name="e_NextFrame"></ref>
                        </optional>
                        <optional>
                            <ref name="e_NextRow"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Paragraph"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PlaceObject"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ProcessNode"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SaveXML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetVariable"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Switch"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Td"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Tr"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Until"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Value"></ref>
                        </optional>
                        <optional>
                            <ref name="e_While"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_PageFormat">
        <element name="PageFormat">
            <a:documentation>The size of the PDF pages. Defaults to 210mm width and 297mm height (A4).</a:documentation>
            <attribute name="height">
                <a:documentation>The height of the PDF pages.</a:documentation>
            </attribute>
            <attribute name="width">
                <a:documentation>Width of the PDF pages.</a:documentation>
            </attribute>
            <empty></empty>
        </element>
    </define>
    <define name="e_Paragraph">
        <element name="Paragraph">
            <a:documentation>Insert a paragraph of text. The width of the paragraph is inherited from the surrounding element.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS class for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS style for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <zeroOrMore>
                        <choice>
                            <ref name="e_A"></ref>
                            <ref name="e_Action"></ref>
                            <ref name="e_B"></ref>
                            <ref name="e_Br"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_I"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_U"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                            <ref name="e_CopyOf"></ref>
                            <ref name="e_Span"></ref>
                        </choice>
                    </zeroOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Param">
        <element name="Param">
            <a:documentation>Specify a parameter for a function definition.</a:documentation>
            <optional>
                <attribute name="name">
                    <a:documentation>The name of the parameter.</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_PDFOptions">
        <element name="PDFOptions">
            <a:documentation>Set PDF options</a:documentation>
            <optional>
                <attribute name="author">
                    <a:documentation>Set the author of the document</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="creator">
                    <a:documentation>Set the creator application of the document</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="displaymode">
                    <a:documentation>Select the display mode when opening PDF document (mainly with Acrobat).</a:documentation>
                    <choice>
                        <value>attachments</value>
                        <a:documentation>Display the attachment pane.</a:documentation>
                        <value>bookmarks</value>
                        <a:documentation>Display the bookmarks pane (only works if the PDF document contains at least one bookmark).</a:documentation>
                        <value>fullscreen</value>
                        <a:documentation>Open the document in fullscreen mode.</a:documentation>
                        <value>none</value>
                        <a:documentation>Do not display a special pane.</a:documentation>
                        <value>thumbnails</value>
                        <a:documentation>Display the thumbnail pane.</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="duplex">
                    <a:documentation>Set viewer preference to one or two page printing. Default: empty.</a:documentation>
                    <choice>
                        <value>simplex</value>
                        <a:documentation>One page per sheet</a:documentation>
                        <value>duplexflipshortedge</value>
                        <a:documentation>Two pages per sheet and flip on short edge</a:documentation>
                        <value>duplexfliplongedge</value>
                        <a:documentation>Two pages per sheet and flip on long edge</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="picktraybypdfsize">
                    <a:documentation>Activate the check box in the PDF viewer for choosing the paper tray based on the page size.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Activate checkbox</a:documentation>
                        <value>no</value>
                        <a:documentation>Deactivate checkbox</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="printscaling">
                    <a:documentation>Should the printer scale the pages?</a:documentation>
                    <choice>
                        <value>appdefault</value>
                        <a:documentation>Use the default from the PDF viewer</a:documentation>
                        <value>none</value>
                        <a:documentation>No page scaling</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="showhyperlinks">
                    <a:documentation>Show hyperlinks in Adobe Acrobat and perhaps other PDF viewers.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <value>no</value>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="subject">
                    <a:documentation>Set the subject of the document</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="title">
                    <a:documentation>Set the title of the document</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_PlaceObject">
        <element name="PlaceObject">
            <a:documentation>Outputs a rectangular object (image, table, box or textblock).</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="allocate">
                            <a:documentation>Determines if the area of the object is marked as “allocated”. With allocate=&#34;no&#34;, the cursor position is not changed.</a:documentation>
                            <choice>
                                <value>yes</value>
                                <a:documentation>Occupy space in the grid (default for grid positioning).</a:documentation>
                                <value>no</value>
                                <a:documentation>Don&#39;t allocate space in the grid (default for absolute positioning).</a:documentation>
                            </choice>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="area">
                            <a:documentation>Name of the positioning area where the object should be placed.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="background">
                            <a:documentation>Fill the background of the object with a color, given by backgroundcolor.</a:documentation>
                            <choice>
                                <value>yes</value>
                                <value>no</value>
                            </choice>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="backgroundcolor">
                            <a:documentation>Color of the background if “background” is set to “yes”.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="column">
                            <a:documentation>If contents is a number: the grid cell from the left margin of the area. If it is a length: the absolute position from the left paper margin. If this attribute is omitted, the system tries to place the object by itself.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="frame">
                            <a:documentation>Draw a frame around the object.</a:documentation>
                            <choice>
                                <value>yes</value>
                                <value>no</value>
                            </choice>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="slate">
                            <a:documentation>The name of the slate that gets output. When given, PlaceObject should not contain any objects.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="halign">
                            <a:documentation>When an object is placed on the grid and it&#39;s width is not a multiple of grid width, there is a space left on the page between the object an the next grid cell. With this attribute you can instruct the software where to place the gap.</a:documentation>
                            <choice>
                                <value>left</value>
                                <a:documentation>The object is aligned at the left.</a:documentation>
                                <value>right</value>
                                <a:documentation>The object is aligned to the right.</a:documentation>
                                <data type="string">
                                    <param name="pattern">\{.+\}</param>
                                </data>
                            </choice>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="hreference">
                            <a:documentation>Determines the placement of the object relative to the given column. If &#39;left&#39; (which is the default), the given column is the left border of the object. If &#39;right&#39;, the column determines the right edge of the object.</a:documentation>
                            <choice>
                                <value>left</value>
                                <a:documentation>The object is placed in given column.</a:documentation>
                                <value>center</value>
                                <a:documentation>The given column determines the horizontal center of the object.</a:documentation>
                                <value>right</value>
                                <a:documentation>The given columns determines the right edge of the border.</a:documentation>
                                <data type="string">
                                    <param name="pattern">\{.+\}</param>
                                </data>
                            </choice>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="row">
                            <a:documentation>The row where the object is placed. If none given, the publisher tries to find a row by itself. You can give a number (in grid cells) or an absolute value (from top left).</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="vreference">
                            <a:documentation>Determines the placement of the object relative to the given row. If &#39;top&#39; (default), the row specifies the top edge. If &#39;bottom&#39;, the row specifies the bottom edge. If &#39;middle&#39;, the row specifies the vertical center.</a:documentation>
                            <choice>
                                <value>top</value>
                                <a:documentation>The given row determines the top edge of the object (default).</a:documentation>
                                <value>middle</value>
                                <a:documentation>The given row determines the vertical center of the object.</a:documentation>
                                <value>bottom</value>
                                <a:documentation>The given row determines the bottom edge of the object.</a:documentation>
                                <data type="string">
                                    <param name="pattern">\{.+\}</param>
                                </data>
                            </choice>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Box"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Circle"></ref>
                            </optional>
                            <optional>
                                <ref name="e_HTML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Image"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Table"></ref>
                            </optional>
                            <optional>
                                <ref name="e_TextBlock"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_PositioningArea">
        <element name="PositioningArea">
            <a:documentation>Describes an area which contains one or more frames. Elements can be placed within these frames.</a:documentation>
            <interleave>
                <group>
                    <attribute name="name">
                        <a:documentation>Name of the area.</a:documentation>
                    </attribute>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_PositioningFrame"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Switch"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_PositioningFrame">
        <element name="PositioningFrame">
            <a:documentation>Defines a rectangular area for objects.</a:documentation>
            <attribute name="width">
                <a:documentation>The width of the frame in grid cells.</a:documentation>
            </attribute>
            <attribute name="height">
                <a:documentation>The height of the frame in grid cells.</a:documentation>
            </attribute>
            <attribute name="row">
                <a:documentation>The row number relative to the grid.</a:documentation>
            </attribute>
            <attribute name="column">
                <a:documentation>First column of the frame, in grid cells.</a:documentation>
            </attribute>
            <empty></empty>
        </element>
    </define>
    <define name="e_ProcessNode">
        <element name="ProcessNode">
            <a:documentation>Executes all given nodes. The elements, that are to be executed, are given with the attribute selection.</a:documentation>
            <attribute name="select">
                <a:documentation>Selection of child elements, that are to be processed.</a:documentation>
            </attribute>
            <optional>
                <attribute name="mode">
                    <a:documentation>Name of the mode. This must match the mode at the corresponding Record element. With this it is possible to have different rules for the same element.</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Record">
        <element name="Record">
            <a:documentation>Contains the instructions to be executed when a data element matches the given match expression. The Record matching the root element will be called automatically, all further data handling must be done by the user via ProcessNode. Match expressions support XPath predicates for conditional matching (similar to XSLT template matching).</a:documentation>
            <interleave>
                <group>
                    <attribute name="match">
                        <a:documentation>An XPath match expression. This can be a simple element name (e.g. data) or an element name followed by an XPath predicate in brackets (e.g. item[@type=&#39;invoice&#39;] or item[not(@hidden=&#39;true&#39;)]). When multiple Records match the same element, Records with predicates take priority over those without. Among Records with predicates, the last defined one wins.</a:documentation>
                    </attribute>
                    <optional>
                        <attribute name="mode">
                            <a:documentation>Name of the mode that matches the mode in ProcessNode.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <optional>
                            <ref name="e_ClearPage"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ForAll"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Slate"></ref>
                        </optional>
                        <optional>
                            <ref name="e_LoadXML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Loop"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Message"></ref>
                        </optional>
                        <optional>
                            <ref name="e_NextFrame"></ref>
                        </optional>
                        <optional>
                            <ref name="e_NextRow"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PlaceObject"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ProcessNode"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SaveXML"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetVariable"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Switch"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Until"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Value"></ref>
                        </optional>
                        <optional>
                            <ref name="e_While"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_SaveXML">
        <element name="SaveXML">
            <a:documentation>Saves an element/attribute structure to be used in the next publisher run. The contents must have a tree structure.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="href">
                            <a:documentation>Name of the file. Example: toc.xml</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="name">
                            <a:documentation>Name of the file. Example: toc</a:documentation>
                        </attribute>
                    </optional>
                    <attribute name="elementname">
                        <a:documentation>Name of the root element that surrounds the elements given by the child elements.</a:documentation>
                    </attribute>
                    <optional>
                        <attribute name="select">
                            <a:documentation>Alternative to giving the data structure in the child elements.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <optional>
                            <ref name="e_Element"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ForAll"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Loop"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Value"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Section">
        <element name="Section">
            <a:documentation>A structural grouping element for organizing the layout. Has no effect on the output.</a:documentation>
            <interleave>
                <group>
                    <attribute name="name">
                        <a:documentation>Name of this section (for documentation purposes only).</a:documentation>
                    </attribute>
                    <oneOrMore>
                        <optional>
                            <ref name="e_DefineColor"></ref>
                        </optional>
                        <optional>
                            <ref name="e_DefineMasterPage"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Function"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Message"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Options"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PDFOptions"></ref>
                        </optional>
                        <optional>
                            <ref name="e_PageFormat"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Record"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Section"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetGrid"></ref>
                        </optional>
                        <optional>
                            <ref name="e_SetVariable"></ref>
                        </optional>
                        <optional>
                            <ref name="e_StyleSheet"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Trace"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_SetGrid">
        <element name="SetGrid">
            <a:documentation>Set size of the grid cells. All objects are placed in the grid.</a:documentation>
            <optional>
                <attribute name="width">
                    <a:documentation>The width of a grid cell. Use either width or nx, not both.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="height">
                    <a:documentation>The height of a grid cell. Use either height or ny, but not both.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="nx">
                    <a:documentation>Specify the number of grid cells in horizontal direction. Use either nx or width, not both.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="ny">
                    <a:documentation>Set the number of grid cells in vertical direction. Give ny or height, but not both.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="dx">
                    <a:documentation>Gap between two grid cells (horizontal)</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="dy">
                    <a:documentation>Gap between two grid cells (horizontal)</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
      <sch:pattern>
        <sch:rule context="t:SetVariable">
          <sch:assert test="not(  not(empty(@select)) and node()  )">SetVariable: either use select Attribute _or_ child elements, but not both.</sch:assert>
        </sch:rule>
      </sch:pattern>
    
    <define name="e_SetVariable">
        <element name="SetVariable">
            <a:documentation>Associates a value with a variable name. The value can be a simple value or a more complex one consisting of several elements.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="select">
                            <a:documentation>The value of the contents.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="trace">
                            <a:documentation>Show information about the assignment in the log file.</a:documentation>
                            <choice>
                                <value>yes</value>
                                <a:documentation>Show information.</a:documentation>
                                <value>no</value>
                                <a:documentation>Don&#39;t show information (default).</a:documentation>
                            </choice>
                        </attribute>
                    </optional>
                    <attribute name="variable">
                        <a:documentation>The name of the variable that holds the contents.</a:documentation>
                    </attribute>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_CopyOf"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Element"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Paragraph"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Table"></ref>
                            </optional>
                            <optional>
                                <ref name="e_TextBlock"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Until"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                            <optional>
                                <ref name="e_While"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Span">
        <element name="Span">
            <a:documentation>Surround text by styling options.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS class for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>Set the CSS style.</a:documentation>
                        </attribute>
                    </optional>
                    <zeroOrMore>
                        <choice>
                            <ref name="e_A"></ref>
                            <ref name="e_Action"></ref>
                            <ref name="e_B"></ref>
                            <ref name="e_Br"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_I"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_U"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                            <ref name="e_CopyOf"></ref>
                            <ref name="e_Span"></ref>
                        </choice>
                    </zeroOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Switch">
        <element name="Switch">
            <a:documentation>Create an if-then-else construct. The test attribute of each Case commands is evaluated until it yields true. The contents of the Case gets executed. If no test succeeds, the (optional) Otherwise gets executed.</a:documentation>
            <interleave>
                <group>
                    <oneOrMore>
                        <ref name="e_Case"></ref>
                    </oneOrMore>
                    <optional>
                        <ref name="e_Otherwise"></ref>
                    </optional>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_StyleSheet">
        <element name="StyleSheet">
            <a:documentation>Load a CSS file or define CSS rules</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="href">
                            <a:documentation>The filename of the CSS stylesheet including the file extension.</a:documentation>
                        </attribute>
                    </optional>
                    <text></text>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Table">
        <element name="Table">
            <a:documentation>Create a table that is similar to the HTML table model.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="width">
                            <a:documentation>The maximum width of the table (in grid cells or absolute values). Defaults to the available space.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS class for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS style for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="stretch">
                            <a:documentation>If set to &#34;max&#34;, the table stretches to its full width (equivalent to CSS width: 100%).</a:documentation>
                            <choice>
                                <value>max</value>
                                <a:documentation>Stretch the table to its maximum width.</a:documentation>
                            </choice>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Columns"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Loop"></ref>
                            </optional>
                            <optional>
                                <ref name="e_TableHead"></ref>
                            </optional>
                            <optional>
                                <ref name="e_TableRule"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Tr"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_TableHead">
        <element name="TableHead">
            <a:documentation>Create a repeating table head.</a:documentation>
            <interleave>
                <group>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Switch"></ref>
                            </optional>
                            <optional>
                                <ref name="e_TableRule"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Tr"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_TableRule">
        <element name="TableRule">
            <a:documentation>Draw a horizontal rule spanning the full table width. Default thickness is 0.4pt.</a:documentation>
            <optional>
                <attribute name="rulewidth">
                    <a:documentation>Thickness of the rule. Defaults to 0.4pt.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="color">
                    <a:documentation>Color of the rule. Use &#34;transparent&#34; for an invisible spacer. Defaults to black.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="class">
                    <a:documentation>CSS class for this element.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="id">
                    <a:documentation>CSS id for this element.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="style">
                    <a:documentation>CSS style for this element. Overrides rulewidth and color attributes.</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Td">
        <element name="Td">
            <a:documentation>Td wraps a table cell, just like HTML.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>The css class to be used for formatting the table cell.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id for this table cell.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS style for this table cell.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="colspan">
                            <a:documentation>The number of columns for this cell. Defaults to 1.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="rowspan">
                            <a:documentation>The number of rows for this cell. Defaults to 1.</a:documentation>
                        </attribute>
                    </optional>
                    <zeroOrMore>
                        <choice>
                            <ref name="e_Bookmark"></ref>
                            <ref name="e_Box"></ref>
                            <ref name="e_ForAll"></ref>
                            <ref name="e_SlateContents"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_Image"></ref>
                            <ref name="e_Loop"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_Paragraph"></ref>
                            <ref name="e_Switch"></ref>
                            <ref name="e_Table"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                        </choice>
                    </zeroOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_TextBlock">
        <element name="TextBlock">
            <a:documentation>Create a rectangular piece of text.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="parsep">
                            <a:documentation>The vertical distance between two paragraphs.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="width">
                            <a:documentation>Number of columns for the text. If not given, the surrounding element determines the width of the element.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <choice>
                            <ref name="e_Action"></ref>
                            <ref name="e_ForAll"></ref>
                            <ref name="e_Bookmark"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_Paragraph"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                        </choice>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Tr">
        <element name="Tr">
            <a:documentation>Tablerow</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS class for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS style for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <optional>
                            <ref name="e_Message"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Td"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Value"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Switch"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ForAll"></ref>
                        </optional>
                        <optional>
                            <ref name="e_Loop"></ref>
                        </optional>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Trace">
        <element name="Trace">
            <a:documentation>Set debugging switches</a:documentation>
            <optional>
                <attribute name="dests">
                    <a:documentation>Draw PDF destinations with a black circle.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Show dest.</a:documentation>
                        <value>no</value>
                        <a:documentation>Don&#39;t show dests (default).</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="grid">
                    <a:documentation>Draw the grid on the page.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Show the grid.</a:documentation>
                        <value>no</value>
                        <a:documentation>Don&#39;t show the grid (default).</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="gridallocation">
                    <a:documentation>Draw allocated cells with yellow and conflicts with red markers.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Show grid allocation.</a:documentation>
                        <value>no</value>
                        <a:documentation>Don&#39;t show the grid allocation (default).</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="hyperlinks">
                    <a:documentation>Draw a box around hyperlinks.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Show the hyperlinks.</a:documentation>
                        <value>no</value>
                        <a:documentation>Don&#39;t show the hyperlinks (default).</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="hyphenation">
                    <a:documentation>Draw little marks to show all hyphenation points.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Show hyphenation points.</a:documentation>
                        <value>no</value>
                        <a:documentation>Don&#39;t show any hyphenation points (default).</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <optional>
                <attribute name="objects">
                    <a:documentation>Draw boxes around objects.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Show boxes.</a:documentation>
                        <value>no</value>
                        <a:documentation>Don&#39;t show the bounding boxes of objects.</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_Ul">
        <element name="Ul">
            <a:documentation>Create an unordered list, just like in HTML</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS class for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS style for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Li"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_U">
        <element name="U">
            <a:documentation>Underline text.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="class">
                            <a:documentation>CSS class for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="id">
                            <a:documentation>CSS id for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="style">
                            <a:documentation>CSS style for this element.</a:documentation>
                        </attribute>
                    </optional>
                    <zeroOrMore>
                        <choice>
                            <ref name="e_A"></ref>
                            <ref name="e_Action"></ref>
                            <ref name="e_B"></ref>
                            <ref name="e_Br"></ref>
                            <ref name="e_HTML"></ref>
                            <ref name="e_I"></ref>
                            <ref name="e_Ol"></ref>
                            <ref name="e_U"></ref>
                            <ref name="e_Ul"></ref>
                            <ref name="e_Value"></ref>
                            <ref name="e_CopyOf"></ref>
                            <ref name="e_Span"></ref>
                        </choice>
                    </zeroOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Until">
        <element name="Until">
            <a:documentation>Create a loop. All child elements are executed repeatedly until the given condition is true. The return value of Until is the concatenated return value of the child elements.</a:documentation>
            <interleave>
                <group>
                    <attribute name="test">
                        <a:documentation>Every time after the the loop is executed, the condition is evaluated. If it is true, the loop exits.</a:documentation>
                    </attribute>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Column"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ClearPage"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                            <optional>
                                <ref name="e_HTML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_LoadXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Loop"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Li"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Message"></ref>
                            </optional>
                            <optional>
                                <ref name="e_NextFrame"></ref>
                            </optional>
                            <optional>
                                <ref name="e_NextRow"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Paragraph"></ref>
                            </optional>
                            <optional>
                                <ref name="e_PlaceObject"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ProcessNode"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SaveXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SetVariable"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Switch"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Td"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Tr"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Until"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                            <optional>
                                <ref name="e_While"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_HTML">
        <element name="HTML">
            <a:documentation>Insert HTML content, either inline or retrieved via an XPath expression.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="select">
                            <a:documentation>XPath expression that yields an XML/HTML fragment.</a:documentation>
                        </attribute>
                    </optional>
                    <optional>
                        <attribute name="expand-text">
                            <a:documentation>If set to &#34;yes&#34;, expressions in curly braces {expr} within the HTML content are evaluated as XPath expressions (similar to XSLT 3.0 text value templates). Use {{ and }} for literal curly braces. Default is &#34;no&#34;.</a:documentation>
                            <choice>
                                <value>yes</value>
                                <value>no</value>
                            </choice>
                        </attribute>
                    </optional>
                    <ref name="html"></ref>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Value">
        <element name="Value">
            <a:documentation>Contains a text value that is passed to the surrounding element (always as plain text).</a:documentation>
            <optional>
                <attribute name="select">
                    <a:documentation>Value to be passed to the outer element.</a:documentation>
                </attribute>
            </optional>
            <ref name="anycontent"></ref>
        </element>
    </define>
    <define name="e_While">
        <element name="While">
            <a:documentation>Create a loop. All child elements are executed as long as the condition in the test attribute evaluates to true.</a:documentation>
            <interleave>
                <group>
                    <attribute name="test">
                        <a:documentation>Every time before the the loop is executed, this condition must evaluate to true. See the command Until for a loop with an exit test.</a:documentation>
                    </attribute>
                    <oneOrMore>
                        <interleave>
                            <optional>
                                <ref name="e_Column"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ClearPage"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ForAll"></ref>
                            </optional>
                            <optional>
                                <ref name="e_HTML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_LoadXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Loop"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Li"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Message"></ref>
                            </optional>
                            <optional>
                                <ref name="e_NextFrame"></ref>
                            </optional>
                            <optional>
                                <ref name="e_NextRow"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Paragraph"></ref>
                            </optional>
                            <optional>
                                <ref name="e_PlaceObject"></ref>
                            </optional>
                            <optional>
                                <ref name="e_ProcessNode"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SaveXML"></ref>
                            </optional>
                            <optional>
                                <ref name="e_SetVariable"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Switch"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Td"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Tr"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Until"></ref>
                            </optional>
                            <optional>
                                <ref name="e_Value"></ref>
                            </optional>
                            <optional>
                                <ref name="e_While"></ref>
                            </optional>
                        </interleave>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
	<!-- allow HTML in <Value> ... </Value> -->
    <define name="htmlclassidstyle">
        <optional><attribute name="class"/></optional>
        <optional><attribute name="id"/></optional>
        <optional><attribute name="style"/></optional>
    </define>
	<define name="html">
		<zeroOrMore>
		    <choice>
			    <element name="a">
				    <attribute name="href"/>
				    <ref name="html"/>
			    </element>
			    <element name="b"><ref name="html" /></element>
			    <element name="barcode">
				    <attribute name="type"/>
				    <attribute name="value"/>
				    <optional><attribute name="width"/></optional>
				    <optional><attribute name="height"/></optional>
				    <optional><attribute name="eclevel"/></optional>
			    </element>
			    <element name="br"><empty /></element>
			    <element name="code"><ref name="html" /></element>
			    <element name="div">
				    <ref name="htmlclassidstyle"/>
				    <ref name="html" />
			    </element>
			    <element name="em"><ref name="html" /></element>
			    <element name="h1"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="h2"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="h3"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="h4"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="h5"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="h6"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="i"><ref name="html" /></element>
			    <element name="img">
				    <attribute name="src"/>
				    <optional><attribute name="width"/></optional>
				    <optional><attribute name="height"/></optional>
				    <optional><attribute name="alt"/></optional>
				    <ref name="htmlclassidstyle"/>
			    </element>
			    <element name="kbd"><ref name="html" /></element>
			    <element name="li"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="ol"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="p">
					<ref name="htmlclassidstyle"/>
				<ref name="html" /></element>
			    <element name="pre"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element name="span"><ref name="html" /><oneOrMore><attribute><anyName/></attribute></oneOrMore></element>
			    <element name="strong"><ref name="html" /></element>
                <element name="table"><ref name="htmltable" /></element>
			    <element name="u"><ref name="html" /></element>
			    <element name="ul"><ref name="htmlclassidstyle"/><ref name="html" /></element>
			    <element>
				    <nsName ns="http://www.w3.org/1999/xhtml"/>
				    <zeroOrMore>
					    <attribute><anyName/></attribute>
				    </zeroOrMore>
				    <ref name="xhtmlcontent"/>
			    </element>
			    <text></text>
		    </choice>
		</zeroOrMore>
	</define>
	<define name="xhtmlcontent">
		<zeroOrMore>
		    <choice>
			    <element>
				    <nsName ns="http://www.w3.org/1999/xhtml"/>
				    <zeroOrMore>
					    <attribute><anyName/></attribute>
				    </zeroOrMore>
				    <ref name="xhtmlcontent"/>
			    </element>
			    <element>
				    <nsName ns="urn:speedata.de/2021/xts/en"/>
				    <zeroOrMore>
					    <attribute><anyName/></attribute>
				    </zeroOrMore>
				    <ref name="xhtmlcontent"/>
			    </element>
			    <text></text>
		    </choice>
		</zeroOrMore>
	</define>
    <define name="htmltable">
        <ref name="htmlclassidstyle"/>
        <zeroOrMore>
            <ref name="colgroup"/>
        </zeroOrMore>
        <optional>
            <element name="thead">
                <ref name="htmlclassidstyle" />
                <oneOrMore>
                    <ref name="tr"/>
                </oneOrMore>
            </element>
        </optional>
        <choice>
            <optional>
                <element name="tbody">
                    <ref name="htmlclassidstyle" />
                    <oneOrMore>
                        <ref name="tr"/>
                    </oneOrMore>
                </element>
            </optional>
            <oneOrMore>
                <ref name="tr"/>
            </oneOrMore>
        </choice>
    </define>
    <define name="colgroup">
        <element name="colgroup">
            <oneOrMore>
                <element name="col">
                    <attribute name="width"/>
                    <empty />
                </element>
            </oneOrMore>
        </element>
    </define>
    <define name="tr">
        <element name="tr">
            <ref name="htmlclassidstyle"/>
            <oneOrMore>
                <choice>
                    <element name="td">
                        <ref name="htmlclassidstyle"></ref>
                        <ref name="html"/>
                    </element>
                    <element name="th">
                        <ref name="htmlclassidstyle"></ref>
                        <ref name="html"/>
                    </element>
                </choice>
            </oneOrMore>
        </element>
    </define>
	<!-- This pattern allows any element from any namespace -->
	<define name="anything">
      <zeroOrMore>
         <choice>
            <element>
               <anyName/>
               <ref name="anything"/>
            </element>
            <attribute>
               <anyName/>
            </attribute>
            <text/>
         </choice>
      </zeroOrMore>
   </define>
   <!-- Like anything but without top-level attributes (for use alongside explicit attributes) -->
   <define name="anycontent">
      <zeroOrMore>
         <choice>
            <element>
               <anyName/>
               <ref name="anything"/>
            </element>
            <text/>
         </choice>
      </zeroOrMore>
   </define>

   <define name="foreign-elements">
      <zeroOrMore>
         <element>
            <anyName>
               <except>
                  <nsName ns=""/>
                  <nsName ns="urn:speedata.de/2021/xts/en"/>
                  <nsName ns="urn:speedata.de/2021/xtsfunctions/en"/>
                  <nsName ns="http://www.w3.org/1999/xhtml"/>
               </except>
            </anyName>
            <ref name="anything"/>
         </element>
      </zeroOrMore>
   </define>
   <define name="foreign-attributes">
      <zeroOrMore>
         <attribute>
            <anyName>
               <except>
                  <nsName ns=""/>
                  <nsName ns="urn:speedata.de/2021/xts/en"/>
                  <nsName ns="urn:speedata.de/2021/xtsfunctions/en"/>
                  <nsName ns="http://www.w3.org/1999/xhtml"/>
               </except>
            </anyName>
         </attribute>
      </zeroOrMore>
   </define>
   <define name="foreign-nodes">
      <zeroOrMore>
         <choice>
            <ref name="foreign-attributes"/>
            <ref name="foreign-elements"/>
         </choice>
      </zeroOrMore>
   </define>

</grammar>
