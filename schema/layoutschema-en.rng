    <define name="e_Bookmark">
        <element name="Bookmark">
            <a:documentation>Create a bookmark for the PDF viewer (e.g. Adobe Reader). When the user clicks on a bookmark, the PDF viewer jumps to that place in the document.</a:documentation>
            <attribute name="level">
                <a:documentation>1 is the top level, 2 is the next level, etc.</a:documentation>
            </attribute>
            <optional>
                <attribute name="open">
                    <a:documentation>If yes, the child elements are shown. If no, the child elements are hidden.</a:documentation>
                    <choice>
                        <value>yes</value>
                        <a:documentation>Show children.</a:documentation>
                        <value>no</value>
                        <a:documentation>Hide children.</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <attribute name="select">
                <a:documentation>Title of the bookmark</a:documentation>
            </attribute>
            <empty></empty>
        </element>
    </define>
    <define name="e_Box">
        <element name="Box">
            <a:documentation>Create a rectangular colored area. The area must fit the grid cells.</a:documentation>
            <optional>
                <attribute name="class">
                    <a:documentation>CSS class for this element.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="id">
                    <a:documentation>CSS id for this element.</a:documentation>
