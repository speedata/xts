                <attribute name="style">
                    <a:documentation>CSS style for this element.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="backgroundcolor">
                    <a:documentation>Color of the box. If the color name is a dash (-), a transparent background is used.</a:documentation>
                </attribute>
            </optional>
            <attribute name="height">
                <a:documentation>Height of the box in grid cells.</a:documentation>
            </attribute>
            <attribute name="width">
                <a:documentation>Width of the box in grid cells or in absolute values.</a:documentation>
            </attribute>
            <empty></empty>
        </element>
    </define>
