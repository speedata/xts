    <define name="e_DefineColor">
        <element name="DefineColor">
            <a:documentation>Colors defined with DefineColors can be referenced later by their name.</a:documentation>
            <optional>
                <attribute name="colorname">
                    <a:documentation>The name of the spot color if model is “spotcolor”. The name must match the required color name, such as “PANTONE 116 C”.</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="model">
                    <a:documentation>Color model to be used for the color. Currently “rgb”, “cmyk”, “gray” and “spotcolor” are supported.</a:documentation>
                    <choice>
                        <value>cmyk</value>
                        <a:documentation>CMYK (cyan, magenta, yellow, key/black), values between 0 and 100 (100 = full intensity)</a:documentation>
                        <value>rgb</value>
                        <a:documentation>rgb (red, green, blue), values between 0 and 100, 100 means full intensity</a:documentation>
                        <value>RGB</value>
                        <a:documentation>rgb (red, green, blue), values between 0 and 255, 255 means full intensity</a:documentation>
                        <value>gray</value>
                        <a:documentation>Gray (0=black, 100=white)</a:documentation>
                        <value>spotcolor</value>
                        <a:documentation>Use a PANTONE or HKS color.</a:documentation>
                    </choice>
                </attribute>
            </optional>
            <attribute name="name">
                <a:documentation>The name of the color to be defined.</a:documentation>
            </attribute>
            <optional>
                <attribute name="value">
                    <a:documentation>Hex value of the color, such as #FA5 or #FFAA55 or rgb(255,170,85) or rgba(255,170,85,1).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="r">
                    <a:documentation>Red part with rgb (0-100) or RGB (0-255).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="g">
                    <a:documentation>Green part with rgb (0-100) or RGB (0-255) / gray part when using the model gray (0-100).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="b">
                    <a:documentation>Blue part with rgb (0-100) or RGB (0-255).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="c">
                    <a:documentation>Cyan part with cmyk (0-100).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="m">
                    <a:documentation>Magenta part with cmyk (0-100)</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="y">
                    <a:documentation>Yellow part with cmyk (0-100).</a:documentation>
                </attribute>
            </optional>
            <optional>
                <attribute name="k">
                    <a:documentation>Black part with cmyk (0-100).</a:documentation>
                </attribute>
            </optional>
            <empty></empty>
        </element>
    </define>
    <define name="e_DefineMasterPage">
        <element name="DefineMasterPage">
            <a:documentation>Define a master page. A master page is chosen depending on the criterion given with the attribute “test”.</a:documentation>
            <interleave>
                <group>
                    <optional>
                        <attribute name="margin">
                            <a:documentation>Set the margin of the page (defaults to 1cm for each margin). One to four values can be provided, similar to CSS.</a:documentation>
                        </attribute>
                    </optional>
                    <attribute name="name">
                        <a:documentation>Name of the master page. It is for informational purpose and as a selection for ClearPage.</a:documentation>
                    </attribute>
                    <attribute name="test">
                        <a:documentation>If this xpath expression evaluates to true, this page is taken as a master page.</a:documentation>
                    </attribute>
                    <interleave>
                        <optional>
                            <oneOrMore>
                                <ref name="e_PositioningArea"></ref>
                            </oneOrMore>
                        </optional>
                        <optional>
                            <ref name="e_AtPageCreation"></ref>
                        </optional>
                        <optional>
                            <ref name="e_AtPageShipout"></ref>
                        </optional>
                        <optional>
                            <ref name="e_ForAll"></ref>
                        </optional>
                    </interleave>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_Element">
