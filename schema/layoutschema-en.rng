                            <ref name="e_Value"></ref>
                        </choice>
                    </oneOrMore>
                </group>
                <ref name="foreign-nodes"></ref>
            </interleave>
        </element>
    </define>
    <define name="e_CopyOf">
        <element name="CopyOf">
            <a:documentation>Copies the result of an XPath expression as-is, preserving node structure. Analogous to xsl:copy-of in XSLT.</a:documentation>
            <attribute name="select">
                <a:documentation>XPath expression whose result is passed through unchanged.</a:documentation>
            </attribute>
            <empty></empty>
        </element>
    </define>
