          <xs:documentation>CSS class for this element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="id">
        <xs:annotation>
          <xs:documentation>CSS id for this element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="style">
        <xs:annotation>
          <xs:documentation>CSS style for this element.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="Until">
    <xs:annotation>
      <xs:documentation>Create a loop. All child elements are executed repeatedly until the given condition is true. The return value of Until is the concatenated return value of the child elements.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="en:Column"/>
        <xs:element ref="en:ClearPage"/>
        <xs:element ref="en:ForAll"/>
        <xs:element ref="en:HTML"/>
        <xs:element ref="en:LoadXML"/>
        <xs:element ref="en:Loop"/>
        <xs:element ref="en:Li"/>
        <xs:element ref="en:Message"/>
        <xs:element ref="en:NextFrame"/>
        <xs:element ref="en:NextRow"/>
        <xs:element ref="en:Paragraph"/>
        <xs:element ref="en:PlaceObject"/>
        <xs:element ref="en:ProcessNode"/>
        <xs:element ref="en:SaveXML"/>
        <xs:element ref="en:SetVariable"/>
        <xs:element ref="en:Switch"/>
        <xs:element ref="en:Td"/>
        <xs:element ref="en:Tr"/>
        <xs:element ref="en:Until"/>
        <xs:element ref="en:Value"/>
        <xs:element ref="en:While"/>
      </xs:choice>
      <xs:attribute name="test" use="required">
        <xs:annotation>
          <xs:documentation>Every time after the the loop is executed, the condition is evaluated. If it is true, the loop exits.</xs:documentation>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="HTML">
    <xs:annotation>
      <xs:documentation>Insert HTML content, either inline or retrieved via an XPath expression.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:complexContent>
        <xs:extension base="en:html">
          <xs:attribute name="select">
            <xs:annotation>
              <xs:documentation>XPath expression that yields an XML/HTML fragment.</xs:documentation>
            </xs:annotation>
          </xs:attribute>
          <xs:attribute name="expand-text">
            <xs:annotation>
              <xs:documentation>If set to "yes", expressions in curly braces {expr} within the HTML content are evaluated as XPath expressions (similar to XSLT 3.0 text value templates). Use {{ and }} for literal curly braces. Default is "no".</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="xs:token">
                <xs:enumeration value="yes"/>
                <xs:enumeration value="no"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:attribute>
        </xs:extension>
      </xs:complexContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="Value">
    <xs:annotation>
      <xs:documentation>Contains a text value that is passed to the surrounding element (always as plain text).</xs:documentation>
    </xs:annotation>
    <xs:complexType>
