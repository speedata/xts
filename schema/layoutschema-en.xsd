            </xs:annotation>
          </xs:attribute>
        </xs:extension>
      </xs:complexContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="While">
    <xs:annotation>
      <xs:documentation>Create a loop. All child elements are executed as long as the condition in the test attribute evaluates to true.</xs:documentation>
    </xs:annotation>
