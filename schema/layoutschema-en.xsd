                <xs:documentation>Open the document in fullscreen mode.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="none">
              <xs:annotation>
                <xs:documentation>Do not display a special pane.</xs:documentation>
              </xs:annotation>
            </xs:enumeration>
